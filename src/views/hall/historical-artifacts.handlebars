<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Montserrat', sans-serif;
      min-height: 100vh;
      position: relative;
    }
    .artifacts-background {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url('/images/historical-hall/artifacts-background.jpg');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      z-index: 0;
    }
    .top-left-image {
      position: absolute;
      top: 0;
      left: 0;
      z-index: 2;
      width: 78%;
      max-width: 1400px;
      min-width: 250px;
      height: auto;
    }

    /* АДАПТИВНЫЙ ЛОГОТИП - используем относительные единицы */
    .hall-logo {
        position: absolute;
        top: 2%;
        left: 2%;
        z-index: 10;
        width: 25%; /* Используем проценты вместо фиксированных пикселей */
        max-width: 400px; /* Максимальный размер */
        min-width: 40px; /* Минимальный размер */
        height: auto;
        pointer-events: none;
        transition: width 0.3s ease; /* Плавное изменение размера */
    }

    /* Адаптивные размеры для разных экранов */
    @media (max-width: 1200px) {
        .hall-logo {
            width: 22%;
            max-width: 350px;
        }
    }

    @media (max-width: 992px) {
        .hall-logo {
            width: 20%;
            max-width: 300px;
        }
    }

    @media (max-width: 768px) {
        .hall-logo {
            width: 18%;
            max-width: 250px;
            top: 1.5%;
            left: 1.5%;
        }
    }

    @media (max-width: 576px) {
        .hall-logo {
            width: 15%;
            max-width: 180px;
            top: 1%;
            left: 1%;
        }
    }

    @media (max-width: 480px) {
        .hall-logo {
            width: 12%;
            max-width: 120px;
            top: 1%;
            left: 1%;
        }
    }

    .title-image-wrapper {
      position: relative;
      width: 100%;
      height: auto;
      overflow: visible;
      border-radius: 0;
    }
    .title-image-bg {
      position: relative;
      width: 100%;
      height: auto;
      aspect-ratio: auto;
      background-image: url('/images/historical-hall/title-bg.png');
      background-size: 100% 100%;
      background-position: center;
      background-repeat: no-repeat;
      border-radius: 0;
      padding-bottom: 10%;
      transition: transform 0.3s ease;
    }
    .person-name-overlay {
      position: absolute;
      top: 50%;
      right: 8%;
      transform: translateY(-50%);
      color: black;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
      white-space: nowrap;
      font-family: 'Comic Sans MS', 'Comic Sans', cursive;
      pointer-events: none;
      text-align: right;
      display: flex;
      gap: 17px;
      align-items: baseline;
      justify-content: flex-end;
      z-index: 2;
      max-width: 85%;
    }
    .person-surname {
      font-weight: 800;
      font-size: clamp(14px, 4vw, 35px);
      text-transform: uppercase;
      letter-spacing: 2px;
      display: inline-block;
      font-family: 'Comic Sans MS', 'Comic Sans', cursive;
    }
    .person-firstname {
      font-weight: 400;
      font-size: clamp(10px, 3vw, 25px);
      display: inline-block;
      white-space: nowrap;
      font-family: 'Comic Sans MS', 'Comic Sans', cursive;
    }
    .artifacts-content {
      position: relative;
      z-index: 1;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 120px 60px 100px 60px;
    }
    .artifacts-grid-container {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      flex: 1;
    }
    .artifacts-grid {
      display: grid;
      gap: 20px 25px;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      justify-items: center;
      align-items: center;
    }
    .artifact-card {
      position: relative;
      width: 100%;
      max-width: 280px;
      aspect-ratio: 1 / 1;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      cursor: pointer;
      background: transparent;
      transition: transform 0.3s ease;
      border-radius: 0;
      overflow: hidden;
      box-shadow: none;
      outline: none;
      padding: 0;
    }
    .artifact-card:focus { outline: none; }
    .artifact-card::-moz-focus-inner { border: 0; }
    
    .artifact-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      border-radius: 0;
      border: none;
      transition: transform 0.3s ease;
    }
    
    .artifact-name-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      color: white;
      font-size: 32px;
      font-weight: 600;
      font-family: 'Montserrat', sans-serif;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
      padding: 0;
      width: 80%;
      word-wrap: break-word;
      white-space: normal;
      line-height: 1.3;
      pointer-events: none;
      z-index: 1;
    }
    .artifact-card:hover { transform: scale(1.05); }
    .artifact-card:active { transform: scale(0.98); }

    .nav-button {
      position: fixed;
      bottom: 30px;
      z-index: 10;
      width: 180px;
      height: auto;
      cursor: pointer;
      transition: opacity 0.3s ease, transform 0.3s ease;
      border: none;
      background: transparent;
      padding: 0;
      border-radius: 0;
      outline: none;
      opacity: 1;
    }
    .nav-button.disabled {
      opacity: 0.4;
      pointer-events: none;
      cursor: default;
    }
    .nav-button:hover:not(.disabled) { transform: scale(1.05); }
    .nav-button:active:not(.disabled) { transform: scale(0.98); }
    .nav-button-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .back-button { left: 100px; }
    .next-button { right: 100px; }

    .page-info { display: none; }
    .no-artifacts {
      text-align: center;
      padding: 60px;
      background: rgba(255,255,255,0.9);
      border-radius: 20px;
      max-width: 500px;
      margin: 0 auto;
    }
    .no-artifacts p {
      font-size: 18px;
      color: #666;
      margin-bottom: 20px;
    }

    .artifacts-grid.grid-2 {
      gap: 20px 140px;
    }

    @media (max-width: 1024px) {
      .artifacts-content { padding: 100px 40px 80px 40px; }
      .artifacts-grid { gap: 15px 20px; }
      .artifact-name-overlay { font-size: 14px; }
      .artifact-card { max-width: 220px; }
      .nav-button { width: 60px; height: 60px; }
      .artifacts-grid.grid-2 { gap: 20px 80px; }
    }
    @media (max-width: 768px) {
      .artifacts-content { padding: 80px 20px 80px 20px; }
      .artifacts-grid { gap: 15px 15px; }
      .artifact-name-overlay { font-size: 12px; }
      .artifact-card { max-width: 180px; }
      .nav-button { width: 50px; height: 50px; bottom: 20px; }
      .artifacts-grid.grid-2 { gap: 15px 40px; }
    }
    @media (max-width: 480px) {
      .artifacts-content { padding: 70px 15px 70px 15px; }
      .artifacts-grid { gap: 15px; }
      .artifact-name-overlay { font-size: 14px; }
      .artifact-card { max-width: 140px; }
      .nav-button { width: 40px; height: 40px; }
      .artifacts-grid.grid-2 { gap: 15px 20px; }
    }
  </style>
</head>
<body>
  <div class="artifacts-background"></div>

  <!-- Логотип зала в левом верхнем углу -->
    <img class="hall-logo" src="/images/historical-hall/hall-logo.png" alt="Зал исторического краеведения">

  <div class="top-left-image">
    <div class="title-image-wrapper">
      <div class="title-image-bg"></div>
    </div>
  </div>

  <div class="artifacts-content">
    {{#if artifacts.length}}
    <div class="artifacts-grid-container">
      <div class="artifacts-grid" id="artifactsGrid">
        {{#each artifacts}}
        <button class="artifact-card" data-artifact-id="{{_id}}" data-artifact-name="{{name}}">
          <div class="artifact-image" style="background-image: url('{{imagePath}}');"></div>
          <div class="artifact-name-overlay">{{name}}</div>
        </button>
        {{/each}}
      </div>
    </div>
    {{else}}
    <div class="no-artifacts">
      <p>📦 В данный момент артефакты отсутствуют</p>
    </div>
    {{/if}}
  </div>

  <button class="nav-button back-button" id="prevPageBtn">
    <img src="/images/back-button.png" alt="Назад" class="nav-button-img">
  </button>
  <button class="nav-button next-button" id="nextPageBtn">
    <img src="/images/next-button.png" alt="Далее" class="nav-button-img">
  </button>

  <div class="page-info">Страница {{currentPage}} из {{totalPages}}</div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const currentPage = parseInt('{{currentPage}}', 10) || 1;
      const totalPages = parseInt('{{totalPages}}', 10) || 1;

      // Клик по карточке
      document.querySelectorAll('.artifact-card').forEach((card) => {
        card.addEventListener('click', function() {
          const artifactId = this.dataset.artifactId;
          if (artifactId) {
            window.location.href = `/hall/historical-artifact-video/${artifactId}`;
          }
        });
      });

      // Пагинация
      const prevBtn = document.getElementById('prevPageBtn');
      const nextBtn = document.getElementById('nextPageBtn');

      function setPaginationState() {
        if (currentPage <= 1) prevBtn.classList.add('disabled');
        else prevBtn.classList.remove('disabled');

        if (currentPage >= totalPages) nextBtn.classList.add('disabled');
        else nextBtn.classList.remove('disabled');
      }

      prevBtn.addEventListener('click', function(e) {
        if (this.classList.contains('disabled')) return;
        window.location.href = `/hall/historical-artifacts?page=${currentPage - 1}`;
      });

      nextBtn.addEventListener('click', function(e) {
        if (this.classList.contains('disabled')) return;
        window.location.href = `/hall/historical-artifacts?page=${currentPage + 1}`;
      });

      setPaginationState();

      // Настройка сетки
      function setupGridLayout() {
        const grid = document.getElementById('artifactsGrid');
        if (!grid) return;
        const cards = grid.querySelectorAll('.artifact-card');
        const count = cards.length;
        if (count === 0) return;

        grid.classList.remove('grid-1', 'grid-2', 'grid-3', 'grid-4', 'grid-5', 'grid-6');

        let cols = 3, rows = 2, cardMaxWidth = 280;

        if (count === 1) { cols = 1; rows = 1; cardMaxWidth = 500; grid.classList.add('grid-1'); }
        else if (count === 2) { cols = 2; rows = 1; cardMaxWidth = 800; grid.classList.add('grid-2'); }
        else if (count === 3) { cols = 3; rows = 1; cardMaxWidth = 350; grid.classList.add('grid-3'); }
        else if (count === 4) { cols = 2; rows = 2; cardMaxWidth = 300; grid.classList.add('grid-4'); }
        else if (count === 5) { cols = 3; rows = 2; cardMaxWidth = 280; grid.classList.add('grid-5'); }
        else if (count === 6) { cols = 3; rows = 2; cardMaxWidth = 280; grid.classList.add('grid-6'); }

        grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
        grid.style.gridTemplateRows = `repeat(${rows}, auto)`;

        cards.forEach(card => card.style.maxWidth = cardMaxWidth + 'px');

        if (count === 5) {
          if (!grid.querySelector('.grid-placeholder')) {
            const placeholder = document.createElement('div');
            placeholder.className = 'grid-placeholder';
            placeholder.style.display = 'none';
            grid.appendChild(placeholder);
          }
        } else {
          const placeholder = grid.querySelector('.grid-placeholder');
          if (placeholder) placeholder.remove();
        }
      }

      setupGridLayout();

      let resizeTimeout;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(setupGridLayout, 200);
      });
    });
  </script>
</body>
</html>