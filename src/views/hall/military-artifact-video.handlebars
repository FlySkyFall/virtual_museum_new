<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Montserrat', sans-serif;
            height: 100vh;
            overflow: hidden;
            position: relative;
        }
        
        /* Фоновое изображение для военного зала */
        .video-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('/images/military-hall/video-background.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            z-index: 0;
        }
        
        /* Основной контент */
        .video-content {
            position: relative;
            z-index: 2;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 80px;
        }

        /* Левое верхнее изображение - плашка с названием войны */
        .top-left-image {
            position: absolute;
            top: 0;
            left: 0;
            z-index: 2;
        }
        
        .title-image-wrapper {
            position: relative;
            display: inline-block;
        }
        
        .title-image-bg {
            display: block;
            width: 60%;
            height: 50%;
        }
        
        /* Левая половина - кнопки */
        .left-buttons {
            flex: 0.8;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            gap: 40px;
        }
        
        /* Стили для кнопок */
        .nav-button {
            width: 200px;
            height: auto;
            cursor: pointer;
            transition: transform 0.3s ease;
            border: none;
            background: transparent;
            padding: 0;
            margin-left: 100px;
        }
        
        .nav-button:hover {
            transform: scale(1.05);
        }
        
        .nav-button:active {
            transform: scale(0.98);
        }
        
        .nav-button-img {
            width: 100%;
            height: auto;
            display: block;
        }
        
        /* Правая половина - видео в рамке */
        .right-video {
            flex: 1.2;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: -40px;
        }
        
        /* Контейнер для рамки и видео */
        .frame-container {
            position: relative;
            width: 100%;
            max-width: 950px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Изображение-рамка */
        .frame-image {
            display: block;
            width: 80%;
            height: auto;
            object-fit: contain;
        }
        
        /* Видео контейнер - поверх рамки */
        .video-overlay {
            position: absolute;
            top: 47%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 60%;
            height: 81%;
            background: #000;
            overflow: hidden;
        }
        
        /* Rutube видео элемент */
        .video-element {
            width: 100%;
            height: 100%;
            border: none;
            background: #000;
        }
        
        /* Заглушка если нет видео */
        .video-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
            color: white;
            text-align: center;
        }
        
        .video-placeholder .icon {
            font-size: 48px;
            margin-bottom: 15px;
        }
        
        .video-placeholder p {
            font-size: 16px;
            margin-bottom: 5px;
        }
        
        .video-placeholder small {
            font-size: 12px;
            opacity: 0.8;
        }
        
        /* Название артефакта в правом нижнем углу */
        .artifact-name {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 10;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(5px);
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
        }
        
        /* Адаптивность для планшетов */
        @media (max-width: 1024px) {
            .video-content {
                padding: 40px 50px;
            }
            
            .left-buttons {
                flex: 0.7;
                gap: 30px;
            }
            
            .nav-button {
                width: 220px;
            }
            
            .right-video {
                flex: 1.3;
                margin-left: -20px;
            }
            
            .frame-container {
                max-width: 750px;
            }
            
            .video-overlay {
                width: 75%;
                height: 75%;
            }
        }
        
        /* Адаптивность для мобильных устройств */
        @media (max-width: 768px) {
            .video-content {
                flex-direction: column;
                justify-content: center;
                gap: 40px;
                padding: 60px 30px;
            }
            
            .left-buttons {
                flex: none;
                flex-direction: row;
                justify-content: center;
                gap: 20px;
                width: 100%;
            }
            
            .nav-button {
                width: 160px;
                margin-left: 0;
            }
            
            .right-video {
                flex: none;
                width: 100%;
                margin-left: 0;
            }
            
            .frame-container {
                max-width: 600px;
                margin: 0 auto;
            }
            
            .video-overlay {
                width: 72%;
                height: 72%;
            }
            
            .artifact-name {
                bottom: 20px;
                right: 20px;
                font-size: 12px;
                padding: 6px 12px;
            }
        }
        
        /* Адаптивность для маленьких телефонов */
        @media (max-width: 480px) {
            .left-buttons {
                gap: 15px;
            }
            
            .nav-button {
                width: 130px;
            }
            
            .frame-container {
                max-width: 400px;
            }
            
            .video-overlay {
                width: 70%;
                height: 70%;
            }
            
            .video-placeholder .icon {
                font-size: 36px;
            }
            
            .video-placeholder p {
                font-size: 12px;
            }
            
            .artifact-name {
                font-size: 10px;
                padding: 4px 10px;
            }
        }
    </style>
</head>
<body>
    <div class="video-background"></div>

    <!-- Левое верхнее изображение - плашка с названием войны -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="{{war.titleImagePath}}" alt="{{war.name}}" class="title-image-bg">
        </div>
    </div>
    
    <div class="video-content">
        <!-- Левая половина - две кнопки -->
        <div class="left-buttons">
            <!-- Кнопка "Вернуться на главную" -->
            <a href="/" class="nav-button">
                <img src="/images/back-to-main-button.png" alt="Вернуться на главную" class="nav-button-img">
            </a>
            
            <!-- Кнопка "Вернуться к артефактам" -->
            <a href="/hall/military-history/war/{{war._id}}?page={{#if currentPage}}{{currentPage}}{{else}}1{{/if}}" class="nav-button">
                <img src="/images/back-to-artifacts-button.png" alt="Вернуться к артефактам" class="nav-button-img">
            </a>
        </div>
        
        <!-- Правая половина - видео в рамке -->
        <div class="right-video">
            <div class="frame-container">
                <!-- Изображение-рамка -->
                <img src="/images/video-frame.png" alt="Рамка плеера" class="frame-image">
                
                <!-- Видео поверх рамки -->
                <div class="video-overlay">
                    {{#if artifact.rutubeVideoId}}
                    <iframe 
                        class="video-element" 
                        src="https://rutube.ru/embed/{{artifact.rutubeVideoId}}/?autoplay=1"
                        allow="autoplay; encrypted-media; fullscreen"
                        allowfullscreen>
                    </iframe>
                    {{else}}
                    <div class="video-placeholder">
                        <div class="icon">🎬</div>
                        <p>Видео будет добавлено позже</p>
                        <small>{{artifact.name}}</small>
                    </div>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
    
    <!-- Название артефакта -->
    <div class="artifact-name">{{artifact.name}}</div>
    
    <script>
        // Переменные для навигации (если понадобятся)
        const warId = '{{war._id}}';
        const artifactIndex = {{artifactIndex}};
        const currentPage = {{#if currentPage}}{{currentPage}}{{else}}1{{/if}};
    </script>
</body>
</html>