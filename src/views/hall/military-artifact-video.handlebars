<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Montserrat', sans-serif;
            min-height: 100vh;
            background: #0a0a1a;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .video-container {
            width: 100%;
            max-width: 1000px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            padding: 30px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .video-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .video-header h2 {
            color: white;
            font-size: 24px;
            font-weight: 600;
        }
        
        .back-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 10px 25px;
            border-radius: 10px;
            cursor: pointer;
            font-family: 'Montserrat', sans-serif;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .back-btn:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateX(-5px);
        }
        
        .video-wrapper {
            position: relative;
            width: 100%;
            padding-top: 56.25%;
            background: #000;
            border-radius: 15px;
            overflow: hidden;
        }
        
        .video-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
        
        .artifact-info {
            margin-top: 20px;
            color: white;
        }
        
        .artifact-info h3 {
            font-size: 20px;
            margin-bottom: 10px;
        }
        
        .artifact-info p {
            color: rgba(255, 255, 255, 0.7);
            font-size: 14px;
            line-height: 1.6;
        }
        
        .navigation {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
            gap: 15px;
        }
        
        .nav-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            padding: 12px 25px;
            border-radius: 10px;
            cursor: pointer;
            font-family: 'Montserrat', sans-serif;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
            flex: 1;
        }
        
        .nav-btn:hover:not(:disabled) {
            background: rgba(255, 255, 255, 0.1);
            transform: scale(1.02);
        }
        
        .nav-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }
        
        @media (max-width: 768px) {
            .video-container {
                padding: 15px;
            }
            
            .video-header h2 {
                font-size: 18px;
            }
            
            .back-btn {
                padding: 8px 15px;
                font-size: 12px;
            }
            
            .artifact-info h3 {
                font-size: 16px;
            }
            
            .nav-btn {
                padding: 10px 15px;
                font-size: 12px;
            }
        }
    </style>
</head>
<body>
    <div class="video-container">
        <div class="video-header">
            <h2>{{artifact.name}}</h2>
            <button class="back-btn" onclick="window.close()">← Назад</button>
        </div>
        
        <div class="video-wrapper">
            <iframe 
                src="https://rutube.ru/embed/{{artifact.rutubeVideoId}}?autoplay=1"
                frameborder="0"
                allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy">
            </iframe>
        </div>
        
        <div class="artifact-info">
            <h3>{{artifact.name}}</h3>
            {{#if artifact.description}}
            <p>{{artifact.description}}</p>
            {{/if}}
        </div>
        
        <div class="navigation">
            {{#if (gt artifactIndex 0)}}
            <button class="nav-btn" id="prevArtifact">← Предыдущий</button>
            {{else}}
            <button class="nav-btn" disabled>← Предыдущий</button>
            {{/if}}
            
            {{#if (lt artifactIndex (subtract totalArtifacts 1))}}
            <button class="nav-btn" id="nextArtifact">Следующий →</button>
            {{else}}
            <button class="nav-btn" disabled>Следующий →</button>
            {{/if}}
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const warId = '{{warId}}';
            const currentIndex = {{artifactIndex}};
            const total = {{totalArtifacts}};
            
            // Кнопка "Предыдущий"
            const prevBtn = document.getElementById('prevArtifact');
            if (prevBtn) {
                prevBtn.addEventListener('click', function() {
                    const newIndex = currentIndex - 1;
                    window.location.href = `/hall/military-history/war/${warId}/artifact/${newIndex}`;
                });
            }
            
            // Кнопка "Следующий"
            const nextBtn = document.getElementById('nextArtifact');
            if (nextBtn) {
                nextBtn.addEventListener('click', function() {
                    const newIndex = currentIndex + 1;
                    window.location.href = `/hall/military-history/war/${warId}/artifact/${newIndex}`;
                });
            }
            
            // Обработка клавиш
            document.addEventListener('keydown', function(e) {
                if (e.key === 'ArrowLeft' && prevBtn && !prevBtn.disabled) {
                    prevBtn.click();
                } else if (e.key === 'ArrowRight' && nextBtn && !nextBtn.disabled) {
                    nextBtn.click();
                } else if (e.key === 'Escape') {
                    window.close();
                }
            });
        });
    </script>
</body>
</html>