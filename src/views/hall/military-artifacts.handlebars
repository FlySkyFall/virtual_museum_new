<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    body {
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        position: relative;
    }
    
    /* Фоновое изображение */
    .artifacts-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/war-hall/artifacts-background.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }

    /* Левое верхнее изображение - вплотную к углу */
    .top-left-image {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 2;
    }
    
    .title-image-wrapper {
        position: relative;
        display: inline-block;
    }
    
    .title-image-bg {
        display: block;
        width: 60%;
        height: 50%;
    }
    
    /* Текст с названием раздела поверх изображения */
    .section-name-overlay {
        position: absolute;
        top: 50%;
        left: 45%;
        transform: translate(-50%, -50%);
        color: black;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        white-space: nowrap;
        font-family: 'Comic Sans MS', 'Comic Sans', cursive;
        pointer-events: none;
        text-align: center;
        display: flex;
        gap: 10px;
        align-items: baseline;
    }
    
    /* Название раздела - жирным шрифтом */
    .section-title-main {
        font-weight: 800;
        font-size: 28px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
    }
    
    /* Подзаголовок - обычным шрифтом */
    .section-subtitle {
        font-weight: 400;
        font-size: 18px;
        display: inline-block;
    }
    
    /* Основной контент */
    .artifacts-content {
        position: relative;
        z-index: 1;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 120px 60px 100px 60px;
    }
    
    /* Сетка артефактов - 3 колонки, 2 ряда с шахматным порядком */
    .artifacts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: repeat(2, auto);
        gap: 20px 30px;
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        justify-items: center;
    }
    
    /* Шахматный порядок: вторая строка со смещением */
    .artifacts-grid .artifact-card:nth-child(4) {
        grid-column: 1 / 2;
        justify-self: center;
        margin-left: 50%; /* Смещение вправо */
    }
    
    .artifacts-grid .artifact-card:nth-child(5) {
        grid-column: 3 / 4;
        justify-self: center;
        margin-right: 50%; /* Смещение влево */
    }
    
    /* Или используем альтернативный подход с флексбоксом */
    .artifacts-grid-alt {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px 30px;
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
    }
    
    /* Карточка артефакта */
    .artifact-card {
        position: relative;
        width: 180px;
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        background: transparent;
        transition: transform 0.3s ease;
        border-radius: 0;
        overflow: visible;
        box-shadow: none;
        outline: none;
        flex: 0 0 auto;
    }
    
    /* Для шахматного порядка во второй строке */
    .artifact-card.row-2 {
        margin-top: 10px;
    }
    
    .artifact-card.row-2:nth-child(1) {
        margin-right: 50px;
    }
    
    .artifact-card.row-2:nth-child(2) {
        margin-left: 50px;
    }
    
    .artifact-card:focus {
        outline: none;
    }
    
    .artifact-card::-moz-focus-inner {
        border: 0;
    }
    
    .artifact-image {
        width: 100%;
        height: 100%;
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 0;
        box-shadow: none;
        border: none;
        transition: transform 0.3s ease;
    }
    
    /* Текст по центру карточки */
    .artifact-name-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        color: white;
        font-size: 16px;
        font-weight: 600;
        font-family: 'Montserrat', sans-serif;
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8);
        background: transparent;
        padding: 0;
        width: 85%;
        word-wrap: break-word;
        white-space: normal;
        line-height: 1.3;
        pointer-events: none;
    }
    
    .artifact-card:hover {
        transform: scale(1.05);
    }
    
    .artifact-card:active {
        transform: scale(0.98);
    }
    
    /* Навигационные кнопки */
    .nav-button {
        position: fixed;
        bottom: 20px;
        z-index: 10;
        width: 70px;
        height: 70px;
        cursor: pointer;
        transition: transform 0.3s ease;
        border: none;
        background: transparent;
        padding: 0;
        border-radius: 0;
        outline: none;
    }
    
    .nav-button:hover {
        transform: scale(1.05);
    }
    
    .nav-button:active {
        transform: scale(0.98);
    }
    
    .nav-button-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }
    
    /* Кнопка Назад - левый нижний угол */
    .back-button {
        left: 30px;
    }
    
    /* Кнопка Далее - правый нижний угол */
    .next-button {
        right: 30px;
    }
    
    /* Номер страницы */
    .page-info {
        position: fixed;
        bottom: 50px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        padding: 8px 20px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        backdrop-filter: blur(5px);
    }
    
    /* Сообщение если нет артефактов */
    .no-artifacts {
        text-align: center;
        padding: 60px;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 20px;
        max-width: 500px;
        margin: 0 auto;
    }
    
    .no-artifacts p {
        font-size: 18px;
        color: #666;
        margin-bottom: 20px;
    }
    
    /* Адаптивность для планшетов */
    @media (max-width: 1024px) {
        .artifacts-content {
            padding: 100px 40px 80px 40px;
        }
        .artifact-card {
            width: 150px;
            height: 150px;
        }
        .artifact-name-overlay {
            font-size: 14px;
        }
        .nav-button {
            width: 60px;
            height: 60px;
        }
        .artifacts-grid {
            gap: 15px 20px;
        }
    }
    
    @media (max-width: 768px) {
        .artifacts-content {
            padding: 80px 20px 80px 20px;
        }
        
        /* На мобильных делаем 2 колонки */
        .artifacts-grid {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(3, auto);
            gap: 15px;
        }
        
        /* Убираем шахматный порядок на мобильных */
        .artifacts-grid .artifact-card:nth-child(4),
        .artifacts-grid .artifact-card:nth-child(5) {
            grid-column: auto;
            justify-self: center;
            margin: 0;
        }
        
        .artifact-card {
            width: 130px;
            height: 130px;
        }
        
        .artifact-name-overlay {
            font-size: 12px;
        }
        
        .nav-button {
            width: 50px;
            height: 50px;
            bottom: 20px;
        }
        
        .page-info {
            bottom: 40px;
            font-size: 12px;
            padding: 6px 15px;
        }
        
        .section-title-main {
            font-size: 20px;
        }
        
        .section-subtitle {
            font-size: 14px;
        }
    }
    
    @media (max-width: 480px) {
        .artifacts-content {
            padding: 70px 15px 70px 15px;
        }
        
        .artifacts-grid {
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
        
        .artifact-card {
            width: 110px;
            height: 110px;
        }
        
        .artifact-name-overlay {
            font-size: 11px;
        }
        
        .nav-button {
            width: 40px;
            height: 40px;
        }
        
        .section-title-main {
            font-size: 16px;
        }
        
        .section-subtitle {
            font-size: 12px;
        }
    }
    
    /* Для очень маленьких экранов */
    @media (max-width: 360px) {
        .artifact-card {
            width: 90px;
            height: 90px;
        }
        
        .artifact-name-overlay {
            font-size: 9px;
        }
    }
    </style>
</head>
<body>
    <div class="artifacts-background"></div>

    <!-- Левое верхнее изображение с названием раздела -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="/images/war-hall/section-title.png" alt="{{section.title}}" class="title-image-bg">
            <div class="section-name-overlay">
                <span class="section-title-main">{{section.title}}</span>
                {{#if section.subtitle}}
                <span class="section-subtitle">{{section.subtitle}}</span>
                {{/if}}
            </div>
        </div>
    </div>
    
    <div class="artifacts-content">
        {{#if artifacts.length}}
        <div class="artifacts-grid">
            {{#each artifacts}}
            <button class="artifact-card {{#if (gt @index 2)}}row-2{{/if}}" 
                    data-artifact-index="{{@index}}" 
                    data-artifact-name="{{name}}"
                    data-section-id="{{../sectionId}}">
                <div class="artifact-image" style="background-image: url('{{imagePath}}');"></div>
                <div class="artifact-name-overlay">{{name}}</div>
            </button>
            {{/each}}
        </div>
        {{else}}
        <div class="no-artifacts">
            <p>📦 В данном разделе пока нет артефактов</p>
        </div>
        {{/if}}
    </div>
    
    <!-- Кнопка Назад (возврат на страницу зала) -->
    {{#if (gt currentPage 1)}}
    <button class="nav-button back-button" id="prevPageBtn">
        <img src="/images/war-hall/back-button.png" alt="Назад" class="nav-button-img">
    </button>
    {{else}}
    <!-- Если это первая страница, кнопка Назад ведет в зал -->
    <a href="/hall/war-history" class="nav-button back-button" style="position: fixed; bottom: 20px; left: 30px; z-index: 10; width: 70px; height: 70px;">
        <img src="/images/war-hall/back-button.png" alt="Назад" class="nav-button-img" style="width: 100%; height: 100%; object-fit: contain;">
    </a>
    {{/if}}
    
    <!-- Кнопка Далее -->
    {{#if (lt currentPage totalPages)}}
    <button class="nav-button next-button" id="nextPageBtn">
        <img src="/images/war-hall/next-button.png" alt="Далее" class="nav-button-img">
    </button>
    {{/if}}
    
    <!-- Информация о странице -->
    <div class="page-info">
        Страница {{currentPage}} из {{totalPages}}
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработчики для карточек артефактов
            const artifactCards = document.querySelectorAll('.artifact-card');
            const sectionId = '{{sectionId}}';
            const currentPage = {{currentPage}};
            const totalPages = {{totalPages}};
            
            artifactCards.forEach((card) => {
                card.addEventListener('click', function() {
                    const artifactIndex = card.dataset.artifactIndex;
                    console.log(`Переход к видео артефакта с индексом: ${artifactIndex}`);
                    showNotification(`Загрузка артефакта...`);
                    window.location.href = `/hall/military-artifact-video/${sectionId}/${artifactIndex}`;
                });
            });
            
            // Пагинация - кнопка Назад (если не первая страница)
            const prevPageBtn = document.getElementById('prevPageBtn');
            if (prevPageBtn) {
                prevPageBtn.addEventListener('click', function() {
                    const prevPage = currentPage - 1;
                    window.location.href = `/hall/military-artifacts/${sectionId}?page=${prevPage}`;
                });
            }
            
            // Пагинация - кнопка Далее
            const nextPageBtn = document.getElementById('nextPageBtn');
            if (nextPageBtn) {
                nextPageBtn.addEventListener('click', function() {
                    const nextPage = currentPage + 1;
                    window.location.href = `/hall/military-artifacts/${sectionId}?page=${nextPage}`;
                });
            }
            
            function showNotification(message) {
                const existingNotification = document.querySelector('.military-artifact-notification');
                if (existingNotification) existingNotification.remove();
                
                const notification = document.createElement('div');
                notification.className = 'military-artifact-notification';
                notification.textContent = message;
                notification.style.cssText = `
                    position: fixed;
                    bottom: 100px;
                    left: 50%;
                    transform: translateX(-50%);
                    background: rgba(0, 0, 0, 0.8);
                    color: white;
                    padding: 12px 24px;
                    border-radius: 12px;
                    z-index: 1000;
                    font-family: 'Montserrat', sans-serif;
                    font-size: 14px;
                    font-weight: 600;
                    box-shadow: 0 5px 20px rgba(0,0,0,0.3);
                    animation: fadeInUp 0.3s ease-out;
                    pointer-events: none;
                `;
                
                document.body.appendChild(notification);
                
                setTimeout(() => {
                    notification.style.animation = 'fadeOutDown 0.3s ease-out';
                    setTimeout(() => notification.remove(), 300);
                }, 2000);
            }
            
            // Добавляем стили для уведомлений
            const style = document.createElement('style');
            style.textContent = `
                @keyframes fadeInUp {
                    from { opacity: 0; transform: translateX(-50%) translateY(20px); }
                    to { opacity: 1; transform: translateX(-50%) translateY(0); }
                }
                @keyframes fadeOutDown {
                    from { opacity: 1; transform: translateX(-50%) translateY(0); }
                    to { opacity: 0; transform: translateX(-50%) translateY(20px); }
                }
            `;
            document.head.appendChild(style);
        });
    </script>
</body>
</html>