<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Montserrat', sans-serif;
            height: 100vh;
            overflow: hidden;
            position: relative;
        }
        
        /* Фоновое изображение */
        .video-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('/images/literary-hall/video-background.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            z-index: 0;
        }
        
        /* Основной контент */
        .video-content {
            position: relative;
            z-index: 2;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 80px;
            gap: 20px; /* отступ между блоками */
        }

        /* Левое верхнее изображение - вплотную к углу */
        .top-left-image {
            position: absolute;
            top: 0;
            left: 0;
            z-index: 2;
        }
        
        .title-image-wrapper {
            position: relative;
            display: inline-block;
        }
        
        .title-image-bg {
            display: block;
            width: 60%;
            height: 50%;
        }
        
        /* Текст с ФИО поверх изображения */
        .person-name-overlay {
            position: absolute;
            top: 50%;
            left: 45%;
            transform: translate(-50%, -50%);
            color: black;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            white-space: nowrap;
            font-family: 'Comic Sans MS', 'Comic Sans', cursive;
            pointer-events: none;
            text-align: center;
            display: flex;
            gap: 10px;
            align-items: baseline;
        }
        
        .person-surname {
            font-weight: 800;
            font-size: 32px;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
        }
        
        .person-firstname {
            font-weight: 400;
            font-size: 20px;
            display: inline-block;
        }
        
        /* ===== ЛЕВАЯ ЧАСТЬ – ВИДЕО ===== */
        .left-video {
            flex: 1.2;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Контейнер для рамки и видео – увеличен по ширине */
        .frame-container {
            position: relative;
            width: 100%;
            max-width: 1000px; /* слегка увеличен */
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Рамка – шире и ниже (за счёт ширины 85% и автоматической высоты) */
        .frame-image {
            display: block;
            width: 85%;         /* было 80% – сделали шире */
            height: auto;
            object-fit: contain;
        }
        
        /* Видео поверх рамки – шире и ниже (чтобы убрать чёрные полосы) */
        .video-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 75%;         /* было 60% – шире */
            height: 60%;        /* было 81% – ниже */
            background: #000;
            overflow: hidden;
        }
        
        .video-element {
            width: 100%;
            height: 100%;
            object-fit: contain;
            background: #000;
        }
        
        /* Заглушка если нет видео */
        .video-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-align: center;
        }
        
        .video-placeholder .icon {
            font-size: 48px;
            margin-bottom: 15px;
        }
        
        .video-placeholder p {
            font-size: 16px;
            margin-bottom: 5px;
        }
        
        .video-placeholder small {
            font-size: 12px;
            opacity: 0.8;
        }
        
        /* ===== ПРАВАЯ ЧАСТЬ – КНОПКИ ===== */
        .right-buttons {
            flex: 0.8;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            gap: 40px;
        }
        
        .nav-button {
            width: 200px;
            height: auto;
            cursor: pointer;
            transition: transform 0.3s ease;
            border: none;
            background: transparent;
            padding: 0;
            margin-left: 100px; /* отступ слева, чтобы кнопки были правее */
        }
        
        .nav-button:hover {
            transform: scale(1.05);
        }
        
        .nav-button:active {
            transform: scale(0.98);
        }
        
        .nav-button-img {
            width: 100%;
            height: auto;
            display: block;
        }
        
        /* Название артефакта в правом нижнем углу (оставляем) */
        .artifact-name {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 10;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(5px);
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
        }
        
        /* ===== АДАПТИВНОСТЬ ===== */
        @media (max-width: 1024px) {
            .video-content {
                padding: 40px 50px;
                gap: 15px;
            }
            
            .left-video {
                flex: 1.3;
            }
            
            .right-buttons {
                flex: 0.7;
                gap: 30px;
            }
            
            .nav-button {
                width: 180px;
                margin-left: 60px;
            }
            
            .frame-container {
                max-width: 800px;
            }
            
            .video-overlay {
                width: 72%;
                height: 58%;
            }
        }
        
        @media (max-width: 768px) {
            .video-content {
                flex-direction: column-reverse; /* кнопки сверху, видео снизу */
                justify-content: center;
                gap: 30px;
                padding: 60px 30px;
            }
            
            .left-video {
                flex: none;
                width: 100%;
            }
            
            .right-buttons {
                flex: none;
                flex-direction: row;
                justify-content: center;
                gap: 20px;
                width: 100%;
            }
            
            .nav-button {
                width: 160px;
                margin-left: 0;
            }
            
            .frame-container {
                max-width: 600px;
                margin: 0 auto;
            }
            
            .video-overlay {
                width: 72%;
                height: 55%;
            }
            
            .artifact-name {
                bottom: 20px;
                right: 20px;
                font-size: 12px;
                padding: 6px 12px;
            }
        }
        
        @media (max-width: 480px) {
            .right-buttons {
                gap: 15px;
            }
            
            .nav-button {
                width: 130px;
            }
            
            .frame-container {
                max-width: 400px;
            }
            
            .video-overlay {
                width: 70%;
                height: 50%;
            }
            
            .video-placeholder .icon {
                font-size: 36px;
            }
            
            .video-placeholder p {
                font-size: 12px;
            }
            
            .artifact-name {
                font-size: 10px;
                padding: 4px 10px;
            }
        }
    </style>
</head>
<body>
    <div class="video-background"></div>

    <!-- Левое верхнее изображение с ФИО (без изменений) -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="/images/literary-hall/person-title.png" alt="Литературное краеведение" class="title-image-bg">
            <div class="person-name-overlay">
                <span class="person-surname">{{person.lastName}}</span>
                <span class="person-firstname">{{person.firstName}} {{person.patronymic}}</span>
            </div>
        </div>
    </div>
    
    <div class="video-content">
        <!-- Левая половина – видео (было справа) -->
        <div class="left-video">
            <div class="frame-container">
                <!-- Изображение-рамка (можно заменить файл, имя оставить) -->
                <img src="/images/video-frame.png" alt="Рамка плеера" class="frame-image">
                
                <!-- Видео поверх рамки -->
                <div class="video-overlay">
                    {{#if artifact.videoUrl}}
                    <iframe 
                        class="video-element" 
                        src="https://drive.google.com/file/d/{{artifact.videoId}}/preview"
                        allow="autoplay"
                        allowfullscreen>
                    </iframe>
                    {{else}}
                    <div class="video-placeholder">
                        <div class="icon">📹</div>
                        <p>Видео будет добавлено позже</p>
                        <small>{{artifact.name}}</small>
                    </div>
                    {{/if}}
                </div>
            </div>
        </div>
        
        <!-- Правая половина – кнопки (были слева) -->
        <div class="right-buttons">
            <!-- Кнопка "Вернуться на главную" -->
            <a href="/" class="nav-button">
                <img src="/images/back-to-main-button.png" alt="Вернуться на главную" class="nav-button-img">
            </a>
            
            <!-- Кнопка "Вернуться к артефактам" -->
            <a href="/hall/artifacts/{{personId}}?page={{#if currentPage}}{{currentPage}}{{else}}1{{/if}}" class="nav-button">
                <img src="/images/back-to-artifacts-button.png" alt="Вернуться к артефактам" class="nav-button-img">
            </a>
        </div>
    </div>
    
    <script>
        // Переменные для навигации (оставляем)
        const personId = '{{personId}}';
        const artifactIndex = {{artifactIndex}};
        const currentPage = {{currentPage}};
    </script>
</body>
</html>