<div class="hall-container">
    <!-- Фоновое изображение зала -->
    <div class="hall-background"></div>

    <!-- Логотип зала в левом верхнем углу -->
    <img class="hall-logo" src="/images/literary-hall/hall-logo.png" alt="Зал литературного краеведения">
    
    <!-- Контейнер с кнопками персоналий -->
    <div class="persons-container" id="personsContainer">
        {{#each persons}}
        <button class="person-button" data-person-id="{{_id}}" data-person-name="{{fullName}}">
            <div class="person-button-bg" style="background-image: url('{{buttonImagePath}}');"></div>
            <div class="person-info">
                <div class="person-name">
                    <span class="person-surname">{{lastName}}</span>
                    <span class="person-name-rest">{{firstName}} {{patronymic}}</span>
                </div>
            </div>
        </button>
        {{/each}}
    </div>

    <!-- Кнопка "Назад" вместо пагинации -->
    <div class="back-container">
        <button class="back-btn" id="backToMain">
            <div class="back-bg"></div>
        </button>
    </div>
</div>