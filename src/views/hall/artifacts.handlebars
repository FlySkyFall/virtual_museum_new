<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
    /* Основной контент - увеличиваем отступы */
.artifacts-content {
    position: relative;
    z-index: 1;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 140px 60px 120px 60px; /* увеличили отступы */
}

/* Сетка артефактов - увеличиваем размер */
.artifacts-grid {
    display: grid;
    gap: 30px 35px; /* увеличили отступы между карточками */
    width: 100%;
    max-width: 1400px; /* увеличили максимальную ширину */
    margin: 0 auto;
    justify-items: center;
    align-items: center;
}

/* Карточка артефакта - увеличиваем размер */
.artifact-card {
    position: relative;
    width: 100%;
    max-width: 350px; /* увеличили с 280px */
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    background: transparent;
    transition: transform 0.3s ease;
    border-radius: 0;
    overflow: visible;
    box-shadow: none;
    outline: none;
}

.artifact-image {
    width: 100%;
    height: auto;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    border-radius: 0;
    box-shadow: none;
    border: none;
    aspect-ratio: 1 / 1;
    transition: transform 0.3s ease;
    min-height: 200px; /* минимальная высота для карточки */
}

/* Текст по центру карточки - увеличиваем */
.artifact-name-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: white;
    font-size: 22px; /* увеличили с 18px */
    font-weight: 700; /* сделали жирнее */
    font-family: 'Montserrat', sans-serif;
    text-shadow: none;
    background: transparent;
    padding: 0;
    width: 85%;
    word-wrap: break-word;
    white-space: normal;
    line-height: 1.4;
    pointer-events: none;
}

/* Навигационные кнопки - увеличиваем */
.nav-button {
    position: fixed;
    bottom: 30px;
    z-index: 10;
    width: 90px; /* увеличили с 70px */
    height: 90px; /* увеличили с 70px */
    cursor: pointer;
    transition: transform 0.3s ease, opacity 0.3s ease;
    border: none;
    background: transparent;
    padding: 0;
    border-radius: 0;
    outline: none;
}

.nav-button:disabled {
    opacity: 0.4; /* полупрозрачные, когда неактивны */
    cursor: not-allowed;
    pointer-events: none;
}

.nav-button:hover:not(:disabled) {
    transform: scale(1.05);
}

.nav-button:active:not(:disabled) {
    transform: scale(0.98);
}

.nav-button-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
}

/* Кнопка Назад - левый нижний угол */
.back-button {
    left: 40px;
}

/* Кнопка Далее - правый нижний угол */
.next-button {
    right: 40px;
}

/* Номер страницы - увеличиваем */
.page-info {
    position: fixed;
    bottom: 55px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 10px 25px;
    border-radius: 25px;
    font-size: 16px; /* увеличили с 14px */
    font-weight: 600;
    backdrop-filter: blur(5px);
}

/* Адаптивность для планшетов */
@media (max-width: 1024px) {
    .artifacts-content {
        padding: 120px 40px 100px 40px;
    }
    .artifacts-grid {
        gap: 25px 30px;
        max-width: 1100px;
    }
    .artifact-card {
        max-width: 300px;
    }
    .artifact-name-overlay {
        font-size: 18px;
    }
    .nav-button {
        width: 75px;
        height: 75px;
    }
    .back-button {
        left: 30px;
    }
    .next-button {
        right: 30px;
    }
    .page-info {
        font-size: 14px;
        padding: 8px 20px;
        bottom: 45px;
    }
}

@media (max-width: 768px) {
    .artifacts-content {
        padding: 100px 20px 90px 20px;
    }
    .artifacts-grid {
        gap: 20px 25px;
        max-width: 800px;
    }
    .artifact-card {
        max-width: 250px;
    }
    .artifact-name-overlay {
        font-size: 16px;
    }
    .nav-button {
        width: 60px;
        height: 60px;
        bottom: 25px;
    }
    .back-button {
        left: 20px;
    }
    .next-button {
        right: 20px;
    }
    .page-info {
        font-size: 12px;
        padding: 6px 15px;
        bottom: 40px;
    }
}

@media (max-width: 480px) {
    .artifacts-content {
        padding: 80px 15px 80px 15px;
    }
    .artifacts-grid {
        gap: 15px 20px;
        max-width: 500px;
    }
    .artifact-card {
        max-width: 200px;
    }
    .artifact-image {
        min-height: 150px;
    }
    .artifact-name-overlay {
        font-size: 14px;
    }
    .nav-button {
        width: 50px;
        height: 50px;
        bottom: 20px;
    }
    .back-button {
        left: 15px;
    }
    .next-button {
        right: 15px;
    }
    .page-info {
        font-size: 11px;
        padding: 5px 12px;
        bottom: 35px;
    }
}

/* Для очень маленьких экранов */
@media (max-width: 400px) {
    .artifact-card {
        max-width: 160px;
    }
    .artifact-image {
        min-height: 120px;
    }
    .artifact-name-overlay {
        font-size: 12px;
    }
    .nav-button {
        width: 40px;
        height: 40px;
        bottom: 15px;
    }
    .page-info {
        font-size: 10px;
        padding: 4px 10px;
        bottom: 30px;
    }
}
</style>
</head>
<body>
    <div class="artifacts-background"></div>

    <!-- Левое верхнее изображение с ФИО поверх -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="/images/literary-hall/person-title.png" alt="Литературное краеведение" class="title-image-bg">
            <div class="person-name-overlay">
                <span class="person-surname">{{person.lastName}}</span>
                <span class="person-firstname">{{person.firstName}} {{person.patronymic}}</span>
            </div>
        </div>
    </div>
    
    <div class="artifacts-content">
        {{#if artifacts.length}}
        <div class="artifacts-grid-container">
            <div class="artifacts-grid" id="artifactsGrid">
                {{#each artifacts}}
                <button class="artifact-card" data-artifact-index="{{@index}}" data-artifact-name="{{name}}">
                    <div class="artifact-image" style="background-image: url('{{imagePath}}');"></div>
                    <div class="artifact-name-overlay">{{name}}</div>
                </button>
                {{/each}}
            </div>
        </div>
        {{else}}
        <div class="no-artifacts">
            <p>📦 В данный момент артефакты отсутствуют</p>
        </div>
        {{/if}}
    </div>
    
    <!-- Кнопки навигации - всегда видны -->
    <button class="nav-button back-button" id="prevPageBtn" {{#unless (gt currentPage 1)}}disabled{{/unless}}>
        <img src="/images/back-button.png" alt="Назад" class="nav-button-img">
    </button>
    
    <button class="nav-button next-button" id="nextPageBtn" {{#unless (lt currentPage totalPages)}}disabled{{/unless}}>
        <img src="/images/next-button.png" alt="Далее" class="nav-button-img">
    </button>
    
    <!-- Информация о странице -->
    <div class="page-info">Страница {{currentPage}} из {{totalPages}}</div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработчики для карточек артефактов
            const artifactCards = document.querySelectorAll('.artifact-card');
            const personId = '{{personId}}';
            const currentPage = {{currentPage}};
            const totalPages = {{totalPages}};
            
            artifactCards.forEach((card, index) => {
                card.addEventListener('click', function() {
                    const artifactIndex = card.dataset.artifactIndex;
                    console.log(`Переход к видео артефакта с индексом: ${artifactIndex}`);
                    window.location.href = `/hall/artifact-video/${personId}/${artifactIndex}`;
                });
            });
            
            // Пагинация - кнопка Назад
            const prevPageBtn = document.getElementById('prevPageBtn');
            if (prevPageBtn) {
                prevPageBtn.addEventListener('click', function() {
                    const prevPage = currentPage - 1;
                    window.location.href = `/hall/artifacts/${personId}?page=${prevPage}`;
                });
            }
            
            // Пагинация - кнопка Далее
            const nextPageBtn = document.getElementById('nextPageBtn');
            if (nextPageBtn) {
                nextPageBtn.addEventListener('click', function() {
                    const nextPage = currentPage + 1;
                    window.location.href = `/hall/artifacts/${personId}?page=${nextPage}`;
                });
            }
            
            // Функция для настройки сетки в зависимости от количества карточек
            function setupGridLayout() {
                const grid = document.getElementById('artifactsGrid');
                if (!grid) return;
                
                const cards = grid.querySelectorAll('.artifact-card');
                const count = cards.length;
                
                if (count === 0) return;
                
                // Удаляем предыдущие классы
                grid.classList.remove('grid-1', 'grid-2', 'grid-3', 'grid-4', 'grid-5', 'grid-6');
                
                // Базовая настройка - по умолчанию 3 колонки
                let cols = 3;
                let rows = 2;
                let cardMaxWidth = 350; // увеличили базовый размер
                
                // Настройка в зависимости от количества карточек
                if (count === 1) {
                    cols = 1;
                    rows = 1;
                    cardMaxWidth = 600; // увеличили для одной карточки
                    grid.classList.add('grid-1');
                } else if (count === 2) {
                    cols = 2;
                    rows = 1;
                    cardMaxWidth = 450; // увеличили для двух карточек
                    grid.classList.add('grid-2');
                } else if (count === 3) {
                    cols = 3;
                    rows = 1;
                    cardMaxWidth = 400; // увеличили для трех карточек
                    grid.classList.add('grid-3');
                } else if (count === 4) {
                    cols = 2;
                    rows = 2;
                    cardMaxWidth = 350;
                    grid.classList.add('grid-4');
                } else if (count === 5) {
                    cols = 3;
                    rows = 2;
                    cardMaxWidth = 350;
                    grid.classList.add('grid-5');
                } else if (count === 6) {
                    cols = 3;
                    rows = 2;
                    cardMaxWidth = 350;
                    grid.classList.add('grid-6');
                }
                
                // Применяем настройки сетки
                grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
                grid.style.gridTemplateRows = `repeat(${rows}, auto)`;
                
                // Устанавливаем максимальную ширину карточек
                cards.forEach(card => {
                    card.style.maxWidth = cardMaxWidth + 'px';
                });
                
                // Для 4 карточек центрируем по 2 в ряду
                if (count === 4) {
                    grid.style.justifyItems = 'center';
                }
                
                // Для 5 карточек делаем 3 сверху, 2 снизу с центрированием
                if (count === 5) {
                    // Добавляем пустой div для правильного отображения 3+2
                    const existingPlaceholder = grid.querySelector('.grid-placeholder');
                    if (!existingPlaceholder) {
                        const placeholder = document.createElement('div');
                        placeholder.className = 'grid-placeholder';
                        placeholder.style.display = 'none';
                        grid.appendChild(placeholder);
                    }
                }
            }
            
            // Вызываем функцию настройки после загрузки
            setupGridLayout();
            
            // Добавляем обработчик изменения размера окна для адаптивности
            let resizeTimeout;
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(setupGridLayout, 250);
            });
        });
    </script>
</body>
</html>