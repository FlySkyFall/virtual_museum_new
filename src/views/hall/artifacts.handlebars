<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Montserrat', sans-serif;
      min-height: 100vh;
      position: relative;
    }
    .artifacts-background {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url('/images/literary-hall/artifacts-background.jpg');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      z-index: 0;
    }
    .top-left-image {
      position: absolute;
      top: 0;
      left: 0;
      z-index: 2;
    }
    .title-image-wrapper {
      position: relative;
      display: inline-block;
    }
    .title-image-bg {
      display: block;
      width: 60%;
      height: 50%;
    }
    .person-name-overlay {
      position: absolute;
      top: 50%;
      left: 45%;
      transform: translate(-50%, -50%);
      color: black;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
      white-space: nowrap;
      font-family: 'Comic Sans MS', 'Comic Sans', cursive;
      pointer-events: none;
      text-align: center;
      display: flex;
      gap: 10px;
      align-items: baseline;
    }
    .person-surname {
      font-weight: 800;
      font-size: 32px;
      text-transform: uppercase;
      letter-spacing: 1px;
      display: inline-block;
    }
    .person-firstname {
      font-weight: 400;
      font-size: 20px;
      display: inline-block;
    }
    .artifacts-content {
      position: relative;
      z-index: 1;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 120px 60px 100px 60px;
    }
    .artifacts-header {
      text-align: center;
      margin-bottom: 30px;
    }
    .artifacts-header h1 {
      font-size: 28px;
      color: #333;
      margin-bottom: 5px;
      text-shadow: 2px 2px 4px rgba(255,255,255,0.5);
    }
    .artifacts-header .person-name {
      font-size: 16px;
      color: #667eea;
      font-weight: 600;
    }
    .artifacts-grid-container {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      flex: 1;
    }
    .artifacts-grid {
      display: grid;
      gap: 20px 25px;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      justify-items: center;
      align-items: center;
    }
    /* Карточка артефакта */
    .artifact-card {
      position: relative;
      width: 100%;
      max-width: 280px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      cursor: pointer;
      background: transparent;
      transition: transform 0.3s ease;
      border-radius: 0;
      overflow: visible;
      box-shadow: none;
      outline: none;
    }
    .artifact-card:focus { outline: none; }
    .artifact-card::-moz-focus-inner { border: 0; }
    .artifact-image {
      width: 100%;
      height: auto;
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      border-radius: 0;
      box-shadow: none;
      border: none;
      aspect-ratio: 1 / 1;
      transition: transform 0.3s ease;
    }
    .artifact-name-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      color: white;
      font-size: 18px;
      font-weight: 600;
      font-family: 'Montserrat', sans-serif;
      text-shadow: none;
      background: transparent;
      padding: 0;
      width: 80%;
      word-wrap: break-word;
      white-space: normal;
      line-height: 1.3;
      pointer-events: none;
    }
    .artifact-card:hover { transform: scale(1.05); }
    .artifact-card:active { transform: scale(0.98); }

    /* Навигационные кнопки — всегда видны, но полупрозрачны если неактивны */
    .nav-button {
      position: fixed;
      bottom: 20px;
      z-index: 10;
      width: 70px;
      height: 70px;
      cursor: pointer;
      transition: opacity 0.3s ease, transform 0.3s ease;
      border: none;
      background: transparent;
      padding: 0;
      border-radius: 0;
      outline: none;
      opacity: 1;
    }
    .nav-button.disabled {
      opacity: 0.4;
      pointer-events: none;
      cursor: default;
    }
    .nav-button:hover:not(.disabled) { transform: scale(1.05); }
    .nav-button:active:not(.disabled) { transform: scale(0.98); }
    .nav-button-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .back-button { left: 30px; }
    .next-button { right: 30px; }

    /* Номер страницы — скрыт */
    .page-info {
      display: none;
    }

    .no-artifacts {
      text-align: center;
      padding: 60px;
      background: rgba(255,255,255,0.9);
      border-radius: 20px;
      max-width: 500px;
      margin: 0 auto;
    }
    .no-artifacts p {
      font-size: 18px;
      color: #666;
      margin-bottom: 20px;
    }

    /* ===== СПЕЦИАЛЬНО ДЛЯ 2 АРТЕФАКТОВ: увеличенный gap ===== */
    .artifacts-grid.grid-2 {
      gap: 20px 120px;  /* горизонтальное расстояние увеличено */
    }

    @media (max-width: 1024px) {
      .artifacts-content { padding: 100px 40px 80px 40px; }
      .artifacts-grid { gap: 15px 20px; }
      .artifact-name-overlay { font-size: 14px; }
      .artifact-image { width: 90%; }
      .nav-button { width: 60px; height: 60px; }
      .artifacts-grid.grid-2 { gap: 20px 80px; }
    }
    @media (max-width: 768px) {
      .artifacts-content { padding: 80px 20px 80px 20px; }
      .artifacts-grid { gap: 15px 15px; }
      .artifacts-header h1 { font-size: 28px; }
      .artifact-name-overlay { font-size: 12px; }
      .artifact-image { width: 90%; }
      .nav-button { width: 50px; height: 50px; bottom: 20px; }
      .artifacts-grid.grid-2 { gap: 15px 40px; }
    }
    @media (max-width: 480px) {
      .artifacts-content { padding: 70px 15px 70px 15px; }
      .artifacts-grid { gap: 15px; }
      .artifact-name-overlay { font-size: 14px; }
      .artifact-image { width: 80%; }
      .nav-button { width: 40px; height: 40px; }
      .artifacts-grid.grid-2 { gap: 15px 20px; }
    }
  </style>
</head>
<body>
  <div class="artifacts-background"></div>

  <!-- Левое верхнее изображение с ФИО -->
  <div class="top-left-image">
    <div class="title-image-wrapper">
      <img src="/images/literary-hall/person-title.png" alt="Литературное краеведение" class="title-image-bg">
      <div class="person-name-overlay">
        <span class="person-surname">{{person.lastName}}</span>
        <span class="person-firstname">{{person.firstName}} {{person.patronymic}}</span>
      </div>
    </div>
  </div>

  <div class="artifacts-content">
    {{#if artifacts.length}}
    <div class="artifacts-grid-container">
      <div class="artifacts-grid" id="artifactsGrid">
        {{#each artifacts}}
        <button class="artifact-card" data-artifact-index="{{@index}}" data-artifact-name="{{name}}">
          <div class="artifact-image" style="background-image: url('{{imagePath}}');"></div>
          <div class="artifact-name-overlay">{{name}}</div>
        </button>
        {{/each}}
      </div>
    </div>
    {{else}}
    <div class="no-artifacts">
      <p>📦 В данный момент артефакты отсутствуют</p>
    </div>
    {{/if}}
  </div>

  <!-- Кнопки пагинации ВСЕГДА ВИДНЫ, но с классом .disabled при неактивности -->
  <button class="nav-button back-button" id="prevPageBtn">
    <img src="/images/back-button.png" alt="Назад" class="nav-button-img">
  </button>
  <button class="nav-button next-button" id="nextPageBtn">
    <img src="/images/next-button.png" alt="Далее" class="nav-button-img">
  </button>

  <!-- Скрытая информация о странице (не отображается) -->
  <div class="page-info">Страница {{currentPage}} из {{totalPages}}</div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // ----- Данные из шаблона -----
      const personId = '{{personId}}';
      const currentPage = parseInt('{{currentPage}}', 10) || 1;
      const totalPages = parseInt('{{totalPages}}', 10) || 1;

      // ----- Клик по карточке артефакта -----
      document.querySelectorAll('.artifact-card').forEach((card, index) => {
        card.addEventListener('click', function() {
          const artifactIndex = card.dataset.artifactIndex;
          window.location.href = `/hall/artifact-video/${personId}/${artifactIndex}`;
        });
      });

      // ----- Кнопки пагинации (всегда видны, но disabled) -----
      const prevBtn = document.getElementById('prevPageBtn');
      const nextBtn = document.getElementById('nextPageBtn');

      // Устанавливаем состояние (активна / неактивна)
      function setPaginationState() {
        // Назад: неактивна если currentPage <= 1
        if (currentPage <= 1) {
          prevBtn.classList.add('disabled');
        } else {
          prevBtn.classList.remove('disabled');
        }

        // Далее: неактивна если currentPage >= totalPages
        if (currentPage >= totalPages) {
          nextBtn.classList.add('disabled');
        } else {
          nextBtn.classList.remove('disabled');
        }
      }

      // Обработчики кликов (переход только если кнопка активна)
      prevBtn.addEventListener('click', function(e) {
        if (this.classList.contains('disabled')) return;
        window.location.href = `/hall/artifacts/${personId}?page=${currentPage - 1}`;
      });

      nextBtn.addEventListener('click', function(e) {
        if (this.classList.contains('disabled')) return;
        window.location.href = `/hall/artifacts/${personId}?page=${currentPage + 1}`;
      });

      // Применяем состояние
      setPaginationState();

      // ----- Динамическая сетка в зависимости от кол-ва карточек -----
      function setupGridLayout() {
        const grid = document.getElementById('artifactsGrid');
        if (!grid) return;
        const cards = grid.querySelectorAll('.artifact-card');
        const count = cards.length;
        if (count === 0) return;

        // Удаляем предыдущие классы
        grid.classList.remove('grid-1', 'grid-2', 'grid-3', 'grid-4', 'grid-5', 'grid-6');

        let cols = 3, rows = 2, cardMaxWidth = 280;

        if (count === 1) {
          cols = 1; rows = 1; cardMaxWidth = 500;
          grid.classList.add('grid-1');
        } else if (count === 2) {
          cols = 2; rows = 1; cardMaxWidth = 600;
          grid.classList.add('grid-2');  // <- активируем увеличенный gap для 2 карточек
        } else if (count === 3) {
          cols = 3; rows = 1; cardMaxWidth = 350;
          grid.classList.add('grid-3');
        } else if (count === 4) {
          cols = 2; rows = 2; cardMaxWidth = 300;
          grid.classList.add('grid-4');
        } else if (count === 5) {
          cols = 3; rows = 2; cardMaxWidth = 280;
          grid.classList.add('grid-5');
        } else if (count === 6) {
          cols = 3; rows = 2; cardMaxWidth = 280;
          grid.classList.add('grid-6');
        }

        grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
        grid.style.gridTemplateRows = `repeat(${rows}, auto)`;

        cards.forEach(card => {
          card.style.maxWidth = cardMaxWidth + 'px';
        });

        // Для 5 карточек — добавляем невидимый плейсхолдер, чтобы сохранить 3+2
        if (count === 5) {
          const existing = grid.querySelector('.grid-placeholder');
          if (!existing) {
            const placeholder = document.createElement('div');
            placeholder.className = 'grid-placeholder';
            placeholder.style.display = 'none';
            grid.appendChild(placeholder);
          }
        } else {
          const placeholder = grid.querySelector('.grid-placeholder');
          if (placeholder) placeholder.remove();
        }
      }

      setupGridLayout();

      // Адаптивность при ресайзе
      let resizeTimeout;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(setupGridLayout, 200);
      });
    });
  </script>
</body>
</html>