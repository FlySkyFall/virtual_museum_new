<div class="person-page">
    <!-- Фоновое изображение страницы -->
    <div class="person-background"></div>
    
    <!-- Левое верхнее изображение с ФИО поверх -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <div class="title-image-bg" style="background-image: url('/images/literary-hall/person-title.png');"></div>
            <div class="person-name-overlay">
                <span class="person-surname">{{person.lastName}}</span>
                <span class="person-firstname">{{person.firstName}} {{person.patronymic}}</span>
            </div>
        </div>
    </div>
    
    <!-- Основной контент -->
    <div class="person-content">
        <!-- Левая колонка - краткая биография и кнопка артефактов -->
        <div class="left-column">
            <div class="short-bio">
                {{person.shortBio}}
            </div>
            
            <button class="artifacts-button" id="artifactsButton">
                <img src="/images/artifacts-button-small.png" alt="Артефакты" class="artifacts-button-img">
            </button>
        </div>
        
        <!-- Правая колонка - фото человека -->
        <div class="right-column">
            <img src="{{person.photoPath}}" alt="{{person.fullName}}" class="person-photo">
        </div>
    </div>
    
    <!-- Кнопка назад в правом нижнем углу -->
    <a href="/hall/literary-local-history" class="back-button">
        <img src="/images/back-button.png" alt="Назад" class="back-button-img">
    </a>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    .person-page {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        font-family: 'Montserrat', sans-serif;
    }
    
    /* Фоновое изображение страницы */
    .person-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/literary-hall/hall-background.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }
    
    /* ===== ПЛАШКА - УВЕЛИЧЕННАЯ ДЛИНА ===== */
    .top-left-image {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 2;
        width: 78%; /* Увеличили с 50% до 70% */
        max-width: 1400px; /* Увеличили максимальную ширину */
        min-width: 250px; /* Увеличили минимальную ширину */
        height: auto;
    }
    
    .title-image-wrapper {
        position: relative;
        width: 100%;
        height: auto;
        overflow: visible;
        border-radius: 0;
    }
    
    /* Фоновое изображение - как у кнопок в hall.css */
    .title-image-bg {
        position: relative;
        width: 100%;
        height: auto;
        aspect-ratio: auto;
        background-size: 100% 100%;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 0;
        padding-bottom: 10%; /* Уменьшили с 25% до 20% (плашка стала ниже) */
        transition: transform 0.3s ease;
    }
    
    /* Текст поверх изображения - УМЕНЬШЕННЫЙ */
    .person-name-overlay {
        position: absolute;
        top: 50%;
        right: 8%;
        transform: translateY(-50%);
        color: black;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        white-space: nowrap;
        font-family: 'Comic Sans MS', 'Comic Sans', cursive;
        pointer-events: none;
        text-align: right;
        display: flex;
        gap: 17px; /* Уменьшили gap */
        align-items: baseline;
        justify-content: flex-end;
        z-index: 2;
        max-width: 85%;
    }
    
    .person-surname {
        font-weight: 800;
        font-size: clamp(14px, 4vw, 50px); /* Уменьшили размер */
        text-transform: uppercase;
        letter-spacing: 2px; /* Уменьшили интервал */
        display: inline-block;
        font-family: 'Comic Sans MS', 'Comic Sans', cursive;
    }
    
    .person-firstname {
        font-weight: 300;
        font-size: clamp(10px, 3vw, 50px); /* Уменьшили размер */
        display: inline-block;
        white-space: nowrap;
        font-family: 'Comic Sans MS', 'Comic Sans', cursive;
    }
    
    /* Основной контент */
    .person-content {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 80px;
        padding: 0 80px;
    }
    
    .left-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 40px;
        align-items: flex-start;
        transform: translateY(60px);
        padding-left: 20px;
    }
    
    .short-bio {
        font-size: clamp(14px, 1.2vw, 20px);
        line-height: 1.6;
        color: black;
        text-align: justify;
        background: transparent;
        padding: 0;
        font-weight: 500;
        text-shadow: none;
        max-width: 90%;
    }
    
    .artifacts-button {
        width: 85%;
        max-width: 500px;
        border: none;
        cursor: pointer;
        background: transparent;
        padding: 0;
        transition: transform 0.3s ease;
        margin-left: 45%;
    }
    
    .artifacts-button-img {
        width: 100%;
        height: auto;
        display: block;
    }
    
    .artifacts-button:hover {
        transform: scale(1.05);
    }
    
    .artifacts-button:active {
        transform: scale(0.98);
    }
    
    .right-column {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        padding: 0;
        margin: 0;
    }
    
    .person-photo {
        width: 100%;
        max-height: 80vh;
        object-fit: contain;
        background: transparent;
        border: none;
        outline: none;
        box-shadow: none;
        border-radius: 0;
    }
    
    .back-button {
        position: fixed;
        bottom: 30px;
        right: 100px;
        z-index: 10;
        width: 180px;
        height: auto;
        cursor: pointer;
        transition: transform 0.3s ease;
        display: block;
    }
    
    .back-button-img {
        width: 100%;
        height: auto;
        display: block;
    }
    
    .back-button:hover {
        transform: scale(1.05);
    }
    
    .back-button:active {
        transform: scale(0.98);
    }
    
    /* ============= АДАПТИВНОСТЬ ============= */
    
    @media (max-width: 1024px) {
        .top-left-image {
            width: 75%; /* Увеличили */
            max-width: 850px;
            min-width: 200px;
            top: 2%;
            left: 2%;
        }
        
        .title-image-bg {
            padding-bottom: 22%;
        }
        
        .person-content {
            gap: 40px;
            padding: 0 40px;
        }
        
        .left-column {
            transform: translateY(40px);
            gap: 30px;
        }
        
        .short-bio {
            font-size: clamp(12px, 1.1vw, 16px);
        }
        
        .artifacts-button {
            width: 55%;
            margin-left: 60px;
        }
        
        .back-button {
            width: 140px;
            right: 80px;
            bottom: 25px;
        }
        
        .person-surname {
            font-size: clamp(12px, 2vw, 26px);
        }
        
        .person-firstname {
            font-size: clamp(10px, 1.4vw, 20px);
        }
        
        .person-name-overlay {
            right: 6%;
            gap: 10px;
        }
    }
    
    @media (max-width: 768px) {
        .top-left-image {
            width: 85%; /* Еще увеличили для мобильных */
            max-width: 550px;
            min-width: 180px;
            top: 1.5%;
            left: 1.5%;
        }
        
        .title-image-bg {
            padding-bottom: 25%;
        }
        
        .person-content {
            flex-direction: column-reverse;
            gap: 20px;
            padding: 80px 20px 20px 20px;
            justify-content: center;
        }
        
        .left-column {
            width: 100%;
            align-items: center;
            text-align: center;
            transform: translateY(0);
            gap: 20px;
            padding-left: 0;
        }
        
        .short-bio {
            text-align: center;
            font-size: clamp(12px, 1.8vw, 14px);
            max-width: 100%;
            padding: 0 10px;
        }
        
        .right-column {
            width: 100%;
            max-height: 45vh;
        }
        
        .person-photo {
            max-height: 40vh;
            width: auto;
        }
        
        .artifacts-button {
            width: 50%;
            max-width: 280px;
            margin-left: 0;
        }
        
        .back-button {
            width: 100px;
            bottom: 15px;
            right: 15px;
        }
        
        .person-surname {
            font-size: clamp(11px, 2vw, 18px);
        }
        
        .person-firstname {
            font-size: clamp(9px, 1.4vw, 14px);
        }
        
        .person-name-overlay {
            right: 5%;
            gap: 6px;
        }
    }
    
    @media (max-width: 480px) {
        .top-left-image {
            width: 90%; /* Почти на всю ширину для маленьких экранов */
            max-width: 400px;
            min-width: 140px;
            top: 1%;
            left: 1%;
        }
        
        .title-image-bg {
            padding-bottom: 28%;
        }
        
        .short-bio {
            font-size: clamp(10px, 1.6vw, 12px);
        }
        
        .artifacts-button {
            width: 45%;
            max-width: 200px;
        }
        
        .back-button {
            width: 70px;
            bottom: 10px;
            right: 10px;
        }
        
        .person-surname {
            font-size: clamp(10px, 1.8vw, 14px);
        }
        
        .person-firstname {
            font-size: clamp(8px, 1.3vw, 11px);
        }
        
        .person-name-overlay {
            right: 4%;
            gap: 4px;
        }
    }
    
    @media (max-height: 600px) {
        .top-left-image {
            width: 60%;
            max-width: 700px;
            min-width: 200px;
            top: 1%;
            left: 1%;
        }
        
        .title-image-bg {
            padding-bottom: 18%;
        }
        
        .person-content {
            padding-top: 60px;
            gap: 15px;
        }
        
        .left-column {
            gap: 10px;
        }
        
        .short-bio {
            font-size: clamp(10px, 1.5vw, 14px);
        }
        
        .artifacts-button {
            width: 40%;
            max-width: 200px;
            margin-left: 0;
        }
        
        .right-column {
            max-height: 50vh;
        }
        
        .person-photo {
            max-height: 50vh;
        }
        
        .back-button {
            width: 80px;
            bottom: 10px;
            right: 40px;
        }
        
        .person-surname {
            font-size: clamp(11px, 2vw, 22px);
        }
        
        .person-firstname {
            font-size: clamp(9px, 1.4vw, 16px);
        }
        
        .person-name-overlay {
            right: 7%;
            gap: 8px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const artifactsButton = document.getElementById('artifactsButton');
        
        if (artifactsButton) {
            artifactsButton.addEventListener('click', function() {
                const personId = '{{person._id}}';
                console.log('Переход к артефактам персоналии:', personId);
                window.location.href = `/hall/artifacts/${personId}`;
            });
        }
    });
</script>
