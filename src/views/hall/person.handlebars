<div class="person-page">
    <!-- Фоновое изображение страницы -->
    <div class="person-background"></div>
    
    <!-- Левое верхнее изображение с ФИО поверх -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <!-- Фоновое изображение через CSS -->
            <div class="title-image-bg"></div>
            <!-- Текст поверх -->
            <div class="person-name-overlay">
                <span class="person-surname">{{person.lastName}}</span>
                <span class="person-firstname">{{person.firstName}} {{person.patronymic}}</span>
            </div>
        </div>
    </div>
    
    <!-- Основной контент -->
    <div class="person-content">
        <!-- Левая колонка - краткая биография и кнопка артефактов -->
        <div class="left-column">
            <div class="short-bio">
                {{person.shortBio}}
            </div>
            
            <button class="artifacts-button" id="artifactsButton">
                <img src="/images/artifacts-button-small.png" alt="Артефакты" class="artifacts-button-img">
            </button>
        </div>
        
        <!-- Правая колонка - фото человека -->
        <div class="right-column">
            <img src="{{person.photoPath}}" alt="{{person.fullName}}" class="person-photo">
        </div>
    </div>
    
    <!-- Кнопка назад в правом нижнем углу -->
    <a href="/hall/literary-local-history" class="back-button">
        <img src="/images/back-button.png" alt="Назад" class="back-button-img">
    </a>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    .person-page {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        font-family: 'Montserrat', sans-serif;
    }
    
    /* Фоновое изображение страницы */
    .person-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/literary-hall/hall-background.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }
    
    /* Левое верхнее изображение - ИСПРАВЛЕНО */
    .top-left-image {
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 2;
        width: 35%;
        max-width: 450px;
        min-width: 180px;
    }
    
    .title-image-wrapper {
        position: relative;
        width: 100%;
        padding-bottom: 50%; /* Соотношение сторон 2:1 (как у вашего изображения) */
        overflow: visible;
    }
    
    /* Фоновое изображение через CSS background - ИСПРАВЛЕНО */
    .title-image-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/literary-hall/person-title.png');
        background-size: 100% 100%; /* Растягиваем на весь контейнер */
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 0;
        z-index: 1;
    }
    
    /* Текст с ФИО поверх изображения - ИСПРАВЛЕНО */
    .person-name-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: black;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        white-space: nowrap;
        font-family: 'Comic Sans MS', 'Comic Sans', cursive;
        pointer-events: none;
        text-align: center;
        display: flex;
        gap: 10px;
        align-items: baseline;
        justify-content: center;
        width: 85%;
        z-index: 2;
    }
    
    /* Фамилия - жирным шрифтом и больше */
    .person-surname {
        font-weight: 800;
        font-size: clamp(16px, 2.5vw, 36px);
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
    }
    
    /* Имя и отчество - обычным шрифтом */
    .person-firstname {
        font-weight: 400;
        font-size: clamp(12px, 1.8vw, 24px);
        display: inline-block;
        white-space: nowrap;
    }
    
    /* Основной контент */
    .person-content {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 80px;
        padding: 0 80px;
    }
    
    /* Левая колонка - биография и кнопка (смещены ниже) */
    .left-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 40px;
        align-items: flex-start;
        transform: translateY(60px);
        padding-left: 20px;
    }
    
    /* Краткая биография */
    .short-bio {
        font-size: clamp(14px, 1.2vw, 20px);
        line-height: 1.6;
        color: #2c2c2c;
        text-align: justify;
        background: transparent;
        padding: 0;
        font-weight: 500;
        text-shadow: none;
        max-width: 90%;
    }
    
    /* Кнопка артефактов */
    .artifacts-button {
        width: 65%;
        max-width: 400px;
        border: none;
        cursor: pointer;
        background: transparent;
        padding: 0;
        transition: transform 0.3s ease;
        margin-left: 100px;
    }
    
    .artifacts-button-img {
        width: 100%;
        height: auto;
        display: block;
    }
    
    .artifacts-button:hover {
        transform: scale(1.05);
    }
    
    .artifacts-button:active {
        transform: scale(0.98);
    }
    
    /* Правая колонка - фото человека */
    .right-column {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        padding: 0;
        margin: 0;
    }
    
    .person-photo {
        width: 100%;
        max-height: 80vh;
        object-fit: contain;
        background: transparent;
        border: none;
        outline: none;
        box-shadow: none;
        border-radius: 0;
    }
    
    /* Кнопка назад в правом нижнем углу */
    .back-button {
        position: fixed;
        bottom: 30px;
        right: 120px;
        z-index: 10;
        width: 180px;
        height: auto;
        cursor: pointer;
        transition: transform 0.3s ease;
        display: block;
    }
    
    .back-button-img {
        width: 100%;
        height: auto;
        display: block;
    }
    
    .back-button:hover {
        transform: scale(1.05);
    }
    
    .back-button:active {
        transform: scale(0.98);
    }
    
    /* ============= АДАПТИВНОСТЬ ============= */
    
    /* Планшеты */
    @media (max-width: 1024px) {
        .top-left-image {
            top: 15px;
            left: 15px;
            width: 30%;
            min-width: 150px;
            max-width: 350px;
        }
        
        .person-content {
            gap: 40px;
            padding: 0 40px;
        }
        
        .left-column {
            transform: translateY(40px);
            gap: 30px;
        }
        
        .short-bio {
            font-size: clamp(12px, 1.1vw, 16px);
        }
        
        .artifacts-button {
            width: 55%;
            margin-left: 60px;
        }
        
        .back-button {
            width: 140px;
            right: 80px;
            bottom: 25px;
        }
        
        .person-surname {
            font-size: clamp(14px, 2.2vw, 28px);
        }
        
        .person-firstname {
            font-size: clamp(10px, 1.5vw, 20px);
        }
    }
    
    /* Мобильные устройства */
    @media (max-width: 768px) {
        .top-left-image {
            top: 10px;
            left: 10px;
            width: 35%;
            min-width: 120px;
            max-width: 250px;
        }
        
        .person-content {
            flex-direction: column-reverse;
            gap: 20px;
            padding: 80px 20px 20px 20px;
            justify-content: center;
        }
        
        .left-column {
            width: 100%;
            align-items: center;
            text-align: center;
            transform: translateY(0);
            gap: 20px;
            padding-left: 0;
        }
        
        .short-bio {
            text-align: center;
            font-size: clamp(12px, 1.8vw, 14px);
            max-width: 100%;
            padding: 0 10px;
        }
        
        .right-column {
            width: 100%;
            max-height: 45vh;
        }
        
        .person-photo {
            max-height: 40vh;
            width: auto;
        }
        
        .artifacts-button {
            width: 50%;
            max-width: 280px;
            margin-left: 0;
        }
        
        .back-button {
            width: 100px;
            height: auto;
            bottom: 15px;
            right: 15px;
        }
        
        .person-surname {
            font-size: clamp(12px, 2vw, 18px);
        }
        
        .person-firstname {
            font-size: clamp(10px, 1.5vw, 14px);
        }
        
        .person-name-overlay {
            width: 80%;
            gap: 5px;
        }
    }
    
    /* Очень маленькие экраны */
    @media (max-width: 480px) {
        .top-left-image {
            top: 8px;
            left: 8px;
            width: 40%;
            min-width: 80px;
            max-width: 180px;
        }
        
        .short-bio {
            font-size: clamp(10px, 1.6vw, 12px);
        }
        
        .artifacts-button {
            width: 45%;
            max-width: 200px;
        }
        
        .back-button {
            width: 70px;
            bottom: 10px;
            right: 10px;
        }
        
        .person-surname {
            font-size: clamp(10px, 1.8vw, 14px);
        }
        
        .person-firstname {
            font-size: clamp(8px, 1.2vw, 11px);
        }
        
        .person-name-overlay {
            width: 75%;
            gap: 3px;
        }
    }
    
    /* Для очень маленькой высоты экрана */
    @media (max-height: 600px) {
        .top-left-image {
            width: 25%;
            min-width: 100px;
            max-width: 250px;
            top: 10px;
            left: 10px;
        }
        
        .person-content {
            padding-top: 60px;
            gap: 15px;
        }
        
        .left-column {
            gap: 10px;
        }
        
        .short-bio {
            font-size: clamp(10px, 1.5vw, 14px);
        }
        
        .artifacts-button {
            width: 40%;
            max-width: 200px;
            margin-left: 0;
        }
        
        .right-column {
            max-height: 50vh;
        }
        
        .person-photo {
            max-height: 50vh;
        }
        
        .back-button {
            width: 80px;
            bottom: 10px;
            right: 40px;
        }
        
        .person-surname {
            font-size: clamp(10px, 1.8vw, 20px);
        }
        
        .person-firstname {
            font-size: clamp(8px, 1.2vw, 14px);
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const artifactsButton = document.getElementById('artifactsButton');
        
        if (artifactsButton) {
            artifactsButton.addEventListener('click', function() {
                const personId = '{{person._id}}';
                console.log('Переход к артефактам персоналии:', personId);
                window.location.href = `/hall/artifacts/${personId}`;
            });
        }
    });
</script>