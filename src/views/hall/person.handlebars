<div class="person-page">
    <!-- Фоновое изображение -->
    <div class="person-background"></div>
    
    <!-- Левое верхнее изображение с ФИО поверх -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="/images/literary-hall/person-title.png" alt="Литературное краеведение" class="title-image-bg">
            <div class="person-name-overlay">
                <span class="person-surname">{{person.lastName}}</span>
                <span class="person-firstname">{{person.firstName}} {{person.patronymic}}</span>
            </div>
        </div>
    </div>
    
    <!-- Основной контент -->
    <div class="person-content">
        <!-- Левая колонка - краткая биография и кнопка артефактов -->
        <div class="left-column">
            <div class="short-bio">
                {{person.shortBio}}
            </div>
            
            <button class="artifacts-button" id="artifactsButton">
                <img src="/images/artifacts-button-small.png" alt="Артефакты" class="artifacts-button-img">
            </button>
        </div>
        
        <!-- Правая колонка - фото человека -->
        <div class="right-column">
            <img src="{{person.photoPath}}" alt="{{person.fullName}}" class="person-photo">
        </div>
    </div>
    
    <!-- Кнопка назад в правом нижнем углу -->
    <a href="/hall/literary-local-history" class="back-button">
        <img src="/images/back-button.png" alt="Назад" class="back-button-img">
    </a>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    .person-page {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        font-family: 'Montserrat', sans-serif;
    }
    
    /* Фоновое изображение */
    .person-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/literary-hall/hall-background.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }
    
    
    /* Левое верхнее изображение - вплотную к углу */
    .top-left-image {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 2;
    }
    
    .title-image-wrapper {
        position: relative;
        display: inline-block;
    }
    
    .title-image-bg {
        display: block;
        width: 60%;
        height: 50%;
    }
    
    /* Текст с ФИО поверх изображения - увеличенный размер */
        /* Текст с ФИО поверх изображения - увеличенный размер */
    .person-name-overlay {
        position: absolute;
        top: 50%;
        left: 45%;
        transform: translate(-50%, -50%);
        color: black;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        white-space: nowrap;
        font-family: 'Comic Sans MS', 'Comic Sans', cursive;
        pointer-events: none;
        text-align: center;
        display: flex;
        gap: 10px;
        align-items: baseline;
    }
    
    /* Фамилия - жирным шрифтом и больше */
    .person-surname {
        font-weight: 800;
        font-size: 32px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
    }
    
    /* Имя и отчество - обычным шрифтом */
    .person-firstname {
        font-weight: 400;
        font-size: 20px;
        display: inline-block;
    }
    
    /* Основной контент */
    .person-content {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 80px;
        padding: 0 80px;
    }
    
    /* Левая колонка - биография и кнопка (смещены ниже) */
    .left-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 40px;
        align-items: flex-start;
        transform: translateY(60px);
    }
    
    /* Краткая биография - просто текст без рамки */
    .short-bio {
        font-size: 18px;
        line-height: 1.6;
        color: #2c2c2c;
        text-align: justify;
        background: transparent;
        padding: 0;
        font-weight: 500;
        text-shadow: none;
    }
    
    /* Кнопка артефактов (смещена правее) */
    .artifacts-button {
        width: 75%;
        height: 75%;
        border: none;
        cursor: pointer;
        background: transparent;
        padding: 0;
        transition: transform 0.3s ease;
        margin-left: 150px;
    }
    
    .artifacts-button-img {
        width: 100%;
        height: auto;
        display: block;
    }
    
    .artifacts-button:hover {
        transform: scale(1.05);
    }
    
    .artifacts-button:active {
        transform: scale(0.98);
    }
    
    /* Правая колонка - фото человека */
    .right-column {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        padding: 0;
        margin: 0;
    }
    
    /* Фото - без рамок и фона */
    .person-photo {
        width: 110%;
        height: 110%;
        object-fit: contain;
        background: transparent;
        border: none;
        outline: none;
        box-shadow: none;
        border-radius: 0;
    }
    
    /* Кнопка назад в правом нижнем углу */
    .back-button {
        position: fixed;
        padding-top: 20px;
        bottom: 0px;
        right: 120px;
        z-index: 10;
        width: 200px;
        height: 200px;
        cursor: pointer;
        transition: transform 0.3s ease;
        display: block;
    }
    
    .back-button-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }
    
    .back-button:hover {
        transform: scale(1.05);
    }
    
    .back-button:active {
        transform: scale(0.98);
    }
    
    /* Адаптивность для планшетов */
    @media (max-width: 1024px) {
        .person-content {
            gap: 50px;
            padding: 0 50px;
        }
        
        .left-column {
            transform: translateY(40px);
        }
        
        .short-bio {
            font-size: 16px;
        }
        
        .artifacts-button {
            max-width: 240px;
            margin-left: 20px;
        }
        
        .back-button {
            width: 80px;
            height: 80px;
            right: 100px;
        }
        
        .title-image-bg {
            max-width: 250px;
            max-height: 120px;
        }
        
        .person-surname {
            font-size: 24px;
        }
        
        .person-firstname {
            font-size: 16px;
        }
    }
    
    /* Адаптивность для мобильных устройств */
    @media (max-width: 768px) {
        .person-content {
            flex-direction: column-reverse;
            gap: 30px;
            padding: 100px 30px 30px 30px;
            justify-content: center;
        }
        
        .left-column {
            width: 100%;
            align-items: center;
            text-align: center;
            transform: translateY(0);
        }
        
        .short-bio {
            text-align: center;
            font-size: 14px;
        }
        
        .right-column {
            width: 100%;
        }
        
        .person-photo {
            max-height: 40vh;
        }
        
        .artifacts-button {
            max-width: 200px;
            margin-left: 0;
        }
        
        .back-button {
            width: 60px;
            height: 60px;
            bottom: 20px;
            right: 20px;
        }
        
        .title-image-bg {
            max-width: 200px;
            max-height: 100px;
        }
        
        .person-surname {
            font-size: 18px;
        }
        
        .person-firstname {
            font-size: 12px;
        }
        
        .person-name-overlay {
            white-space: normal;
            width: 150px;
        }
    }
    
    /* Для очень маленьких экранов */
    @media (max-width: 480px) {
        .short-bio {
            font-size: 12px;
        }
        
        .artifacts-button {
            max-width: 160px;
        }
        
        .back-button {
            width: 50px;
            height: 50px;
        }
        
        .title-image-bg {
            max-width: 150px;
            max-height: 80px;
        }
        
        .person-surname {
            font-size: 14px;
        }
        
        .person-firstname {
            font-size: 10px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const artifactsButton = document.getElementById('artifactsButton');
        
        if (artifactsButton) {
            artifactsButton.addEventListener('click', function() {
                const personId = '{{person._id}}';
                console.log('Переход к артефактам персоналии:', personId);
                window.location.href = `/hall/artifacts/${personId}`;
            });
        }
    });
</script>