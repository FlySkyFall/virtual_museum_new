<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    body {
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        position: relative;
    }
    
    /* Фоновое изображение */
    .artifacts-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/military-hall/artifacts-background.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }

    /* Левое верхнее изображение - вплотную к углу */
    .top-left-image {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 2;
    }
    
    .title-image-wrapper {
        position: relative;
        display: inline-block;
    }
    
    .title-image-bg {
        display: block;
        width: 75%;
        height: 50%;
    }
    
    /* Основной контент */
    .artifacts-content {
        position: relative;
        z-index: 1;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 120px 60px 100px 60px;
    }
    
    /* Контейнер для сетки с центрированием */
    .artifacts-grid-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        flex: 1;
    }
    
    /* Сетка артефактов */
    .artifacts-grid {
        display: grid;
        gap: 5px 100px;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        justify-items: center;
        align-items: center;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: auto auto;
    }
    
    /* Шахматный порядок для 5 элементов на десктопе (заменяем старые правила) */
    @media (min-width: 769px) {
        .artifacts-grid.has-5 {
            grid-template-columns: repeat(6, 1fr) !important;
            grid-template-rows: auto auto;
        }

        .artifacts-grid.has-5 .artifact-card:nth-child(1) {
            grid-column: 1 / 3;
            grid-row: 1;
        }
        .artifacts-grid.has-5 .artifact-card:nth-child(2) {
            grid-column: 3 / 5;
            grid-row: 1;
        }
        .artifacts-grid.has-5 .artifact-card:nth-child(3) {
            grid-column: 5 / 7;
            grid-row: 1;
        }
        .artifacts-grid.has-5 .artifact-card:nth-child(4) {
            grid-column: 2 / 4;
            grid-row: 2;
        }
        .artifacts-grid.has-5 .artifact-card:nth-child(5) {
            grid-column: 4 / 6;
            grid-row: 2;
        }
    }
    
    /* Для случаев когда меньше или больше 5 элементов — возвращаем обычное центрирование */
    .artifacts-grid:not(.has-5) .artifact-card {
        grid-column: auto !important;
        justify-self: center !important;
        padding: 0 !important;
    }
    
    /* Карточка артефакта */
    .artifact-card {
        position: relative;
        width: 100%;
        max-width: 300px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        background: transparent;
        transition: transform 0.3s ease;
        border-radius: 0;
        overflow: visible;
        box-shadow: none;
        outline: none;
    }
    
    .artifact-card:focus {
        outline: none;
    }
    
    .artifact-card::-moz-focus-inner {
        border: 0;
    }
    
    .artifact-image {
        width: 100%;
        height: auto;
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 0;
        box-shadow: none;
        border: none;
        aspect-ratio: 1 / 1;
        transition: transform 0.3s ease;
    }
    
    .artifact-card:hover {
        transform: scale(1.05);
    }
    
    .artifact-card:active {
        transform: scale(0.98);
    }
    
    /* Навигационные кнопки */
    .nav-button {
        position: fixed;
        bottom: 30px;
        z-index: 10;
        width: 180px;
        height: auto;
        cursor: pointer;
        transition: transform 0.3s ease;
        border: none;
        background: transparent;
        padding: 0;
        border-radius: 0;
        outline: none;
    }
    
    .nav-button:hover {
        transform: scale(1.05);
    }
    
    .nav-button:active {
        transform: scale(0.98);
    }
    
    .nav-button-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }
    
    /* Кнопка Назад - левый нижний угол */
    .back-button {
        left: 100px;
    }
    
    /* Кнопка Далее - правый нижний угол */
    .next-button {
        right: 100px;
    }
    
    /* Номер страницы - скрыт */
    .page-info {
        display: none;
    }
    
    /* Сообщение если нет артефактов */
    .no-artifacts {
        text-align: center;
        padding: 60px;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 20px;
        max-width: 500px;
        margin: 0 auto;
    }
    
    .no-artifacts p {
        font-size: 18px;
        color: #666;
        margin-bottom: 20px;
    }
    
    /* Адаптивность для планшетов */
    @media (max-width: 1024px) {
        .artifacts-content {
            padding: 100px 40px 80px 40px;
        }
        .artifacts-grid {
            gap: 15px 20px;
            max-width: 800px;
        }
        .artifact-image {
            width: 90%;
        }
        .nav-button {
            width: 60px;
            height: 60px;
        }
        .artifact-card {
            max-width: 240px;
        }
        /* На планшетах шахматный порядок не применяется (медиа-запрос выше срабатывает только от 769px) */
    }
    
    @media (max-width: 768px) {
        .artifacts-content {
            padding: 80px 20px 80px 20px;
        }
        .artifacts-grid {
            gap: 15px 15px;
            max-width: 500px;
            grid-template-columns: repeat(2, 1fr);
        }
        .artifact-image {
            width: 90%;
        }
        .nav-button {
            width: 50px;
            height: 50px;
            bottom: 20px;
        }
        
        /* На мобильных устройствах меняем шахматный порядок (если нужно, можно оставить как есть) */
        .artifacts-grid .artifact-card:nth-child(1) {
            grid-column: 1 / 3;
            max-width: 300px;
        }
        .artifacts-grid .artifact-card:nth-child(2) {
            grid-column: 1 / 2;
            justify-self: center;
            padding: 0;
        }
        .artifacts-grid .artifact-card:nth-child(3) {
            grid-column: 2 / 3;
            justify-self: center;
            padding: 0;
        }
        .artifacts-grid .artifact-card:nth-child(4) {
            grid-column: 1 / 2;
            justify-self: center;
            padding: 0;
        }
        .artifacts-grid .artifact-card:nth-child(5) {
            grid-column: 2 / 3;
            justify-self: center;
            padding: 0;
        }
        .artifact-card {
            max-width: 200px;
        }
    }
    
    @media (max-width: 480px) {
        .artifacts-content {
            padding: 70px 15px 70px 15px;
        }
        .artifacts-grid {
            gap: 12px;
            max-width: 350px;
        }
        .artifact-image {
            width: 80%;
        }
        .nav-button {
            width: 40px;
            height: 40px;
        }
        .artifact-card {
            max-width: 160px;
        }
        .artifacts-grid .artifact-card:nth-child(1) {
            max-width: 250px;
        }
        .artifacts-grid .artifact-card:nth-child(2),
        .artifacts-grid .artifact-card:nth-child(3),
        .artifacts-grid .artifact-card:nth-child(4),
        .artifacts-grid .artifact-card:nth-child(5) {
            max-width: 150px;
        }
    }
</style>
</head>
<body>
    <div class="artifacts-background"></div>

    <!-- Левое верхнее изображение - плашка с названием войны -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="{{war.titleImagePath}}" alt="{{war.name}}" class="title-image-bg">
        </div>
    </div>
    
    <div class="artifacts-content">
        
        {{#if artifacts.length}}
        <div class="artifacts-grid-container">
            <div class="artifacts-grid" id="artifactsGrid">
                {{#each artifacts}}
                <button class="artifact-card" data-artifact-index="{{@index}}" data-artifact-name="{{name}}">
                    <div class="artifact-image" style="background-image: url('{{imagePath}}');"></div>
                </button>
                {{/each}}
            </div>
        </div>
        {{else}}
        <div class="no-artifacts">
            <p>📦 В данный момент артефакты отсутствуют</p>
        </div>
        {{/if}}
    </div>
    
    <!-- Кнопка Назад -->
    {{#if (gt currentPage 1)}}
    <button class="nav-button back-button" id="prevPageBtn">
        <img src="/images/back-button.png" alt="Назад" class="nav-button-img">
    </button>
    {{/if}}
    
    <!-- Кнопка Далее -->
    {{#if (lt currentPage totalPages)}}
    <button class="nav-button next-button" id="nextPageBtn">
        <img src="/images/next-button.png" alt="Далее" class="nav-button-img">
    </button>
    {{/if}}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработчики для карточек артефактов
            const artifactCards = document.querySelectorAll('.artifact-card');
            const warId = '{{war._id}}';
            const currentPage = parseInt('{{currentPage}}');
            const totalPages = parseInt('{{totalPages}}');
            
            artifactCards.forEach((card) => {
                card.addEventListener('click', function() {
                    const artifactIndex = card.dataset.artifactIndex;
                    const artifactName = card.dataset.artifactName;
                    console.log(`Переход к видео артефакта: ${artifactName} (индекс: ${artifactIndex})`);
                    window.location.href = `/hall/military-history/war/${warId}/artifact/${artifactIndex}`;
                });
            });
            
            // Пагинация - кнопка Назад
            const prevPageBtn = document.getElementById('prevPageBtn');
            if (prevPageBtn) {
                prevPageBtn.addEventListener('click', function() {
                    const prevPage = currentPage - 1;
                    window.location.href = `/hall/military-history/war/${warId}?page=${prevPage}`;
                });
            }
            
            // Пагинация - кнопка Далее
            const nextPageBtn = document.getElementById('nextPageBtn');
            if (nextPageBtn) {
                nextPageBtn.addEventListener('click', function() {
                    const nextPage = currentPage + 1;
                    window.location.href = `/hall/military-history/war/${warId}?page=${nextPage}`;
                });
            }
            
            // Добавляем класс has-5 если ровно 5 элементов
            const grid = document.getElementById('artifactsGrid');
            if (grid) {
                const count = grid.querySelectorAll('.artifact-card').length;
                if (count === 5) {
                    grid.classList.add('has-5');
                }
            }
        });
    </script>
</body>
</html>