<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    body {
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        position: relative;
    }
    
    /* Фоновое изображение */
    .artifacts-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/military-hall/artifacts-background.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }

    /* Левое верхнее изображение - вплотную к углу */
    .top-left-image {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 2;
    }
    
    .title-image-wrapper {
        position: relative;
        display: inline-block;
    }
    
    .title-image-bg {
        display: block;
        width: 60%;
        height: 50%;
    }
    
    /* Основной контент */
    .artifacts-content {
        position: relative;
        z-index: 1;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 120px 60px 100px 60px;
    }
    
    /* Контейнер для сетки с центрированием */
    .artifacts-grid-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        flex: 1;
    }
    
    /* Сетка артефактов - динамическая */
    .artifacts-grid {
        display: grid;
        gap: 20px 25px;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        justify-items: center;
        align-items: center;
    }
    
    /* Карточка артефакта */
    .artifact-card {
        position: relative;
        width: 100%;
        max-width: 280px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        background: transparent;
        transition: transform 0.3s ease;
        border-radius: 0;
        overflow: visible;
        box-shadow: none;
        outline: none;
    }
    
    .artifact-card:focus {
        outline: none;
    }
    
    .artifact-card::-moz-focus-inner {
        border: 0;
    }
    
    .artifact-image {
        width: 100%;
        height: auto;
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 0;
        box-shadow: none;
        border: none;
        aspect-ratio: 1 / 1;
        transition: transform 0.3s ease;
    }
    
    .artifact-card:hover {
        transform: scale(1.05);
    }
    
    .artifact-card:active {
        transform: scale(0.98);
    }
    
    /* Навигационные кнопки */
    .nav-button {
        position: fixed;
        bottom: 20px;
        z-index: 10;
        width: 70px;
        height: 70px;
        cursor: pointer;
        transition: transform 0.3s ease;
        border: none;
        background: transparent;
        padding: 0;
        border-radius: 0;
        outline: none;
    }
    
    .nav-button:hover {
        transform: scale(1.05);
    }
    
    .nav-button:active {
        transform: scale(0.98);
    }
    
    .nav-button-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }
    
    /* Кнопка Назад - левый нижний угол */
    .back-button {
        left: 30px;
    }
    
    /* Кнопка Далее - правый нижний угол */
    .next-button {
        right: 30px;
    }
    
    /* Номер страницы - скрыт */
    .page-info {
        display: none;
    }
    
    /* Сообщение если нет артефактов */
    .no-artifacts {
        text-align: center;
        padding: 60px;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 20px;
        max-width: 500px;
        margin: 0 auto;
    }
    
    .no-artifacts p {
        font-size: 18px;
        color: #666;
        margin-bottom: 20px;
    }
    
    /* Адаптивность для планшетов */
    @media (max-width: 1024px) {
        .artifacts-content {
            padding: 100px 40px 80px 40px;
        }
        .artifacts-grid {
            gap: 15px 20px;
        }
        .artifact-image {
            width: 90%;
        }
        .nav-button {
            width: 60px;
            height: 60px;
        }
    }
    
    @media (max-width: 768px) {
        .artifacts-content {
            padding: 80px 20px 80px 20px;
        }
        .artifacts-grid {
            gap: 15px 15px;
        }
        .artifact-image {
            width: 90%;
        }
        .nav-button {
            width: 50px;
            height: 50px;
            bottom: 20px;
        }
    }
    
    @media (max-width: 480px) {
        .artifacts-content {
            padding: 70px 15px 70px 15px;
        }
        .artifacts-grid {
            gap: 15px;
        }
        .artifact-image {
            width: 80%;
        }
        .nav-button {
            width: 40px;
            height: 40px;
        }
    }
</style>
</head>
<body>
    <div class="artifacts-background"></div>

    <!-- Левое верхнее изображение - плашка с названием войны -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="{{war.titleImagePath}}" alt="{{war.name}}" class="title-image-bg">
        </div>
    </div>
    
    <div class="artifacts-content">
        
        {{#if artifacts.length}}
        <div class="artifacts-grid-container">
            <div class="artifacts-grid" id="artifactsGrid">
                {{#each artifacts}}
                <button class="artifact-card" data-artifact-index="{{@index}}" data-artifact-name="{{name}}">
                    <div class="artifact-image" style="background-image: url('{{imagePath}}');"></div>
                </button>
                {{/each}}
            </div>
        </div>
        {{else}}
        <div class="no-artifacts">
            <p>📦 В данный момент артефакты отсутствуют</p>
        </div>
        {{/if}}
    </div>
    
    <!-- Кнопка Назад -->
    {{#if (gt currentPage 1)}}
    <button class="nav-button back-button" id="prevPageBtn">
        <img src="/images/back-button.png" alt="Назад" class="nav-button-img">
    </button>
    {{/if}}
    
    <!-- Кнопка Далее -->
    {{#if (lt currentPage totalPages)}}
    <button class="nav-button next-button" id="nextPageBtn">
        <img src="/images/next-button.png" alt="Далее" class="nav-button-img">
    </button>
    {{/if}}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработчики для карточек артефактов
            const artifactCards = document.querySelectorAll('.artifact-card');
            const warId = '{{war._id}}';
            const currentPage = parseInt('{{currentPage}}');
            const totalPages = parseInt('{{totalPages}}');
            
            artifactCards.forEach((card) => {
                card.addEventListener('click', function() {
                    const artifactIndex = card.dataset.artifactIndex;
                    const artifactName = card.dataset.artifactName;
                    console.log(`Переход к видео артефакта: ${artifactName} (индекс: ${artifactIndex})`);
                    window.location.href = `/hall/military-history/war/${warId}/artifact/${artifactIndex}`;
                });
            });
            
            // Пагинация - кнопка Назад
            const prevPageBtn = document.getElementById('prevPageBtn');
            if (prevPageBtn) {
                prevPageBtn.addEventListener('click', function() {
                    const prevPage = currentPage - 1;
                    window.location.href = `/hall/military-history/war/${warId}?page=${prevPage}`;
                });
            }
            
            // Пагинация - кнопка Далее
            const nextPageBtn = document.getElementById('nextPageBtn');
            if (nextPageBtn) {
                nextPageBtn.addEventListener('click', function() {
                    const nextPage = currentPage + 1;
                    window.location.href = `/hall/military-history/war/${warId}?page=${nextPage}`;
                });
            }
            
            // Функция для настройки сетки в зависимости от количества карточек
            function setupGridLayout() {
                const grid = document.getElementById('artifactsGrid');
                if (!grid) return;
                
                const cards = grid.querySelectorAll('.artifact-card');
                const count = cards.length;
                
                if (count === 0) return;
                
                // Удаляем предыдущие классы
                grid.classList.remove('grid-1', 'grid-2', 'grid-3', 'grid-4', 'grid-5');
                
                // Базовая настройка - по умолчанию 3 колонки
                let cols = 3;
                let rows = 2;
                let cardMaxWidth = 280;
                
                // Настройка в зависимости от количества карточек
                if (count === 1) {
                    cols = 1;
                    rows = 1;
                    cardMaxWidth = 500;
                    grid.classList.add('grid-1');
                } else if (count === 2) {
                    cols = 2;
                    rows = 1;
                    cardMaxWidth = 400;
                    grid.classList.add('grid-2');
                } else if (count === 3) {
                    cols = 3;
                    rows = 1;
                    cardMaxWidth = 350;
                    grid.classList.add('grid-3');
                } else if (count === 4) {
                    cols = 2;
                    rows = 2;
                    cardMaxWidth = 300;
                    grid.classList.add('grid-4');
                } else if (count === 5) {
                    cols = 3;
                    rows = 2;
                    cardMaxWidth = 280;
                    grid.classList.add('grid-5');
                } else if (count === 6) {
                    cols = 3;
                    rows = 2;
                    cardMaxWidth = 280;
                    grid.classList.add('grid-6');
                }
                
                // Применяем настройки сетки
                grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
                grid.style.gridTemplateRows = `repeat(${rows}, auto)`;
                
                // Для 5 карточек делаем шахматный порядок (3 сверху, 2 снизу)
                if (count === 5) {
                    // Добавляем пустую ячейку для правильного отображения 3+2
                    grid.style.gridAutoFlow = 'row';
                }
                
                // Устанавливаем максимальную ширину карточек
                cards.forEach(card => {
                    card.style.maxWidth = cardMaxWidth + 'px';
                });
                
                // Для 4 карточек центрируем по 2 в ряду
                if (count === 4) {
                    grid.style.justifyItems = 'center';
                }
                
                // Для 5 карточек делаем 3 сверху, 2 снизу с центрированием
                if (count === 5) {
                    const existingPlaceholder = grid.querySelector('.grid-placeholder');
                    if (!existingPlaceholder) {
                        const placeholder = document.createElement('div');
                        placeholder.className = 'grid-placeholder';
                        placeholder.style.display = 'none';
                        grid.appendChild(placeholder);
                    }
                }
            }
            
            // Вызываем функцию настройки после загрузки
            setupGridLayout();
            
            // Добавляем обработчик изменения размера окна для адаптивности
            let resizeTimeout;
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(setupGridLayout, 250);
            });
        });
    </script>
</body>
</html>