<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    body {
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        position: relative;
        background: #0a0a1a;
    }
    
    /* Фоновое изображение */
    .war-artifacts-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/military-hall/artifacts-background.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }

    /* Левое верхнее изображение - плашка с названием войны */
    .top-left-image {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 2;
    }
    
    .title-image-wrapper {
        position: relative;
        display: inline-block;
    }
    
    .title-image-bg {
        display: block;
        width: auto;
        height: auto;
        min-width: 350px;
        max-width: 600px;
        min-height: 80px;
    }
    
    /* Основной контент */
    .artifacts-content {
        position: relative;
        z-index: 1;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 140px 60px 100px 60px;
    }
    
    /* Контейнер для сетки с центрированием */
    .artifacts-grid-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        flex: 1;
        padding: 20px 0;
    }
    
    /* Сетка артефактов - шахматный порядок */
    .artifacts-grid {
        display: grid;
        gap: 25px 30px;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        justify-items: center;
        align-items: center;
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: auto;
    }
    
    /* Для 5 элементов - шахматный порядок (3 сверху, 2 снизу) */
    .artifacts-grid.grid-5 {
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: auto auto;
    }
    
    .artifacts-grid.grid-5 .artifact-card:nth-child(4) {
        grid-column: 1 / 2;
        justify-self: center;
    }
    
    .artifacts-grid.grid-5 .artifact-card:nth-child(5) {
        grid-column: 3 / 4;
        justify-self: center;
    }
    
    /* Для 4 элементов - 2x2 */
    .artifacts-grid.grid-4 {
        grid-template-columns: repeat(2, 1fr);
        grid-template-rows: auto auto;
        max-width: 800px;
    }
    
    /* Для 3 элементов - 3 в ряд */
    .artifacts-grid.grid-3 {
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: auto;
        max-width: 900px;
    }
    
    /* Для 2 элементов - 2 в ряд */
    .artifacts-grid.grid-2 {
        grid-template-columns: repeat(2, 1fr);
        grid-template-rows: auto;
        max-width: 600px;
    }
    
    /* Для 1 элемента */
    .artifacts-grid.grid-1 {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
        max-width: 400px;
    }
    
    /* Карточка артефакта - только изображение без текста */
    .artifact-card {
        position: relative;
        width: 100%;
        max-width: 280px;
        aspect-ratio: 1 / 1;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        background: transparent;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 15px;
        overflow: hidden;
        outline: none;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
        padding: 0;
    }
    
    .artifact-card:focus {
        outline: none;
    }
    
    .artifact-card::-moz-focus-inner {
        border: 0;
    }
    
    .artifact-card:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        z-index: 5;
    }
    
    .artifact-card:active {
        transform: scale(0.97);
    }
    
    .artifact-image {
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 15px;
        transition: transform 0.3s ease;
    }
    
    /* Иконка воспроизведения */
    .play-icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 50px;
        height: 50px;
        background: rgba(255, 0, 0, 0.8);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
        transition: transform 0.3s ease, background 0.3s ease;
        pointer-events: none;
        opacity: 0;
    }
    
    .artifact-card:hover .play-icon {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1.1);
        background: rgba(255, 0, 0, 0.9);
    }
    
    .play-icon svg {
        width: 24px;
        height: 24px;
        fill: white;
        margin-left: 3px;
    }
    
    /* Навигационные кнопки */
    .nav-button {
        position: fixed;
        bottom: 30px;
        z-index: 10;
        width: 70px;
        height: 70px;
        cursor: pointer;
        transition: transform 0.3s ease, opacity 0.3s ease;
        border: none;
        background: transparent;
        padding: 0;
        border-radius: 0;
        outline: none;
        opacity: 0.9;
    }
    
    .nav-button:hover {
        transform: scale(1.05);
        opacity: 1;
    }
    
    .nav-button:active {
        transform: scale(0.95);
    }
    
    .nav-button-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }
    
    /* Кнопка Назад - левый нижний угол */
    .back-button {
        left: 30px;
    }
    
    /* Кнопка Далее - правый нижний угол */
    .next-button {
        right: 30px;
    }
    
    /* Номер страницы */
    .page-info {
        position: fixed;
        bottom: 45px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        padding: 8px 25px;
        border-radius: 25px;
        font-size: 14px;
        font-weight: 600;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        font-family: 'Montserrat', sans-serif;
    }
    
    /* Сообщение если нет артефактов */
    .no-artifacts {
        text-align: center;
        padding: 60px;
        background: rgba(0, 0, 0, 0.7);
        border-radius: 20px;
        max-width: 500px;
        margin: 0 auto;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .no-artifacts p {
        font-size: 18px;
        color: #ccc;
        margin-bottom: 20px;
    }
    
    /* Адаптивность для планшетов */
    @media (max-width: 1024px) {
        .artifacts-content {
            padding: 120px 40px 80px 40px;
        }
        .artifacts-grid {
            gap: 20px 25px;
        }
        .artifact-card {
            max-width: 250px;
        }
        .nav-button {
            width: 60px;
            height: 60px;
        }
        .play-icon {
            width: 40px;
            height: 40px;
        }
        .play-icon svg {
            width: 20px;
            height: 20px;
        }
        .title-image-bg {
            min-width: 280px;
            max-width: 450px;
            min-height: 70px;
        }
    }
    
    @media (max-width: 768px) {
        .artifacts-content {
            padding: 100px 20px 80px 20px;
        }
        .artifacts-grid {
            gap: 15px 15px;
        }
        .artifact-card {
            max-width: 200px;
        }
        .nav-button {
            width: 50px;
            height: 50px;
            bottom: 20px;
        }
        .page-info {
            bottom: 35px;
            font-size: 12px;
            padding: 6px 15px;
        }
        .title-image-bg {
            min-width: 220px;
            max-width: 350px;
            min-height: 60px;
        }
        .play-icon {
            width: 35px;
            height: 35px;
        }
        .play-icon svg {
            width: 18px;
            height: 18px;
        }
        
        /* Адаптация шахматного порядка для мобильных */
        .artifacts-grid.grid-5 {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: auto auto auto;
        }
        
        .artifacts-grid.grid-5 .artifact-card:nth-child(1) {
            grid-column: 1 / 3;
            max-width: 300px;
        }
        
        .artifacts-grid.grid-5 .artifact-card:nth-child(2) {
            grid-column: 1 / 2;
        }
        
        .artifacts-grid.grid-5 .artifact-card:nth-child(3) {
            grid-column: 2 / 3;
        }
        
        .artifacts-grid.grid-5 .artifact-card:nth-child(4) {
            grid-column: 1 / 2;
        }
        
        .artifacts-grid.grid-5 .artifact-card:nth-child(5) {
            grid-column: 2 / 3;
        }
    }
    
    @media (max-width: 480px) {
        .artifacts-content {
            padding: 80px 10px 70px 10px;
        }
        .artifacts-grid {
            gap: 12px;
        }
        .artifact-card {
            max-width: 160px;
            border-radius: 10px;
        }
        .artifact-image {
            border-radius: 10px;
        }
        .nav-button {
            width: 40px;
            height: 40px;
            bottom: 15px;
        }
        .back-button {
            left: 15px;
        }
        .next-button {
            right: 15px;
        }
        .page-info {
            bottom: 25px;
            font-size: 10px;
            padding: 4px 12px;
        }
        .title-image-bg {
            min-width: 160px;
            max-width: 250px;
            min-height: 50px;
        }
        .play-icon {
            width: 30px;
            height: 30px;
        }
        .play-icon svg {
            width: 16px;
            height: 16px;
        }
        
        .artifacts-grid.grid-5 {
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        
        .artifacts-grid.grid-5 .artifact-card:nth-child(1) {
            grid-column: 1 / 3;
            max-width: 250px;
        }
        
        .artifacts-grid.grid-4 {
            grid-template-columns: repeat(2, 1fr);
            max-width: 350px;
        }
        
        .artifacts-grid.grid-3 {
            grid-template-columns: repeat(2, 1fr);
            max-width: 350px;
        }
        
        .artifacts-grid.grid-3 .artifact-card:last-child {
            grid-column: 1 / 3;
            max-width: 250px;
        }
    }
</style>
</head>
<body>
    <div class="war-artifacts-background"></div>

    <!-- Левое верхнее изображение - плашка с названием войны -->
    <div class="top-left-image">
        <div class="title-image-wrapper">
            <img src="{{war.titleImagePath}}" alt="{{war.name}}" class="title-image-bg">
        </div>
    </div>
    
    <div class="artifacts-content">
        
        {{#if artifacts.length}}
        <div class="artifacts-grid-container">
            <div class="artifacts-grid" id="artifactsGrid">
                {{#each artifacts}}
                <button class="artifact-card" data-artifact-index="{{@index}}" data-artifact-name="{{name}}" data-video-id="{{rutubeVideoId}}">
                    <div class="artifact-image" style="background-image: url('{{imagePath}}');">
                        <div class="play-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z"/>
                            </svg>
                        </div>
                    </div>
                </button>
                {{/each}}
            </div>
        </div>
        {{else}}
        <div class="no-artifacts">
            <p>📦 В данный момент артефакты отсутствуют</p>
        </div>
        {{/if}}
    </div>
    
    <!-- Кнопка Назад -->
    {{#if (gt currentPage 1)}}
    <button class="nav-button back-button" id="prevPageBtn">
        <img src="/images/back-button.png" alt="Назад" class="nav-button-img">
    </button>
    {{/if}}
    
    <!-- Кнопка Далее -->
    {{#if (lt currentPage totalPages)}}
    <button class="nav-button next-button" id="nextPageBtn">
        <img src="/images/next-button.png" alt="Далее" class="nav-button-img">
    </button>
    {{/if}}
    
    <!-- Информация о странице -->
    <div class="page-info">Страница {{currentPage}} из {{totalPages}}</div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработчики для карточек артефактов
            const artifactCards = document.querySelectorAll('.artifact-card');
            const warId = '{{war._id}}';
            const currentPage = parseInt('{{currentPage}}');
            const totalPages = parseInt('{{totalPages}}');
            
            console.log('Текущая страница:', currentPage);
            console.log('Всего страниц:', totalPages);
            
            artifactCards.forEach((card) => {
                card.addEventListener('click', function() {
                    const artifactIndex = card.dataset.artifactIndex;
                    const artifactName = card.dataset.artifactName;
                    console.log(`Переход к видео артефакта: ${artifactName} (индекс: ${artifactIndex})`);
                    window.location.href = `/hall/military-history/war/${warId}/artifact/${artifactIndex}`;
                });
            });
            
            // Пагинация - кнопка Назад
            const prevPageBtn = document.getElementById('prevPageBtn');
            if (prevPageBtn) {
                prevPageBtn.addEventListener('click', function() {
                    const prevPage = currentPage - 1;
                    window.location.href = `/hall/military-history/war/${warId}?page=${prevPage}`;
                });
            }
            
            // Пагинация - кнопка Далее
            const nextPageBtn = document.getElementById('nextPageBtn');
            if (nextPageBtn) {
                nextPageBtn.addEventListener('click', function() {
                    const nextPage = currentPage + 1;
                    window.location.href = `/hall/military-history/war/${warId}?page=${nextPage}`;
                });
            }
            
            // Функция для настройки сетки в зависимости от количества карточек
            function setupGridLayout() {
                const grid = document.getElementById('artifactsGrid');
                if (!grid) return;
                
                const cards = grid.querySelectorAll('.artifact-card');
                const count = cards.length;
                
                if (count === 0) return;
                
                // Удаляем предыдущие классы
                grid.classList.remove('grid-1', 'grid-2', 'grid-3', 'grid-4', 'grid-5');
                
                // Добавляем класс в зависимости от количества
                if (count <= 1) {
                    grid.classList.add('grid-1');
                } else if (count === 2) {
                    grid.classList.add('grid-2');
                } else if (count === 3) {
                    grid.classList.add('grid-3');
                } else if (count === 4) {
                    grid.classList.add('grid-4');
                } else if (count >= 5) {
                    grid.classList.add('grid-5');
                }
            }
            
            // Вызываем функцию настройки после загрузки
            setTimeout(setupGridLayout, 100);
            
            // Добавляем обработчик изменения размера окна для адаптивности
            let resizeTimeout;
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(setupGridLayout, 250);
            });
        });
    </script>
</body>
</html>