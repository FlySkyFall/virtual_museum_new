<div class="museum-container">
    <img class="museum-background" src="/images/background-placeholder.jpg" alt="Фон музея" style="object-fit: contain;">
    
    <!-- Логотип зала в левом верхнем углу -->
    <img class="hall-logo" src="/images/main-logo.png" alt="Зал литературного краеведения">

    <div class="halls-container">
        {{#each halls}}
        <button class="hall-button" data-hall-id="{{id}}" data-hall-route="{{route}}"
                style="top: {{position.top}}; left: {{position.left}}; width: {{width}}; height: {{height}};">
            <div class="button-image" style="background-image: url('/images/hall{{id}}.png');"></div>
            <!-- Текст удален, так как надпись есть на изображении -->
        </button>
        {{/each}}
    </div>
    

    <script>
        (function() {
            const img = document.querySelector('.museum-container img');
            const w = window.innerWidth;
            const h = window.innerHeight;
            const ratio = (w / h).toFixed(3);
            console.log('=== РЕАЛЬНАЯ ДИАГНОСТИКА ===');
            console.log('Ширина окна:', w);
            console.log('Высота окна:', h);
            console.log('Соотношение экрана:', ratio);
            if (img && img.complete) {
                console.log('Изображение:', img.naturalWidth, 'x', img.naturalHeight);
                console.log('Соотношение картинки:', (img.naturalWidth / img.naturalHeight).toFixed(3));
            }
        })();
    </script>
</div>
